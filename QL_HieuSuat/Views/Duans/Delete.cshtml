@model QL_HieuSuat.Models.Duan

@{
    ViewData["Title"] = "Xóa dự án";

    string trangThaiText = Model.Trangthai switch
    {
        1 => "Chưa bắt đầu",
        2 => "Đang thực hiện",
        3 => "Hoàn thành",
        4 => "Tạm dừng",
        _ => "Không xác định"
    };
}

<div class="container mt-4">
    <div class="card shadow border-danger">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">Xác nhận xóa dự án</h5>
        </div>

        <div class="card-body">
            <div class="alert alert-warning mb-4">
                Bạn có chắc chắn muốn xóa dự án này không?
                Hành động này <strong>không thể hoàn tác</strong> và có thể ảnh hưởng tới dữ liệu liên quan.
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <p class="mb-2"><strong>Mã dự án:</strong> @Model.Maduan</p>
                    <p class="mb-2"><strong>Tên dự án:</strong> @Model.Tenduan</p>
                    <p class="mb-2"><strong>Ngày bắt đầu:</strong> @Model.Ngaybatdau?.ToString("dd/MM/yyyy")</p>
                </div>
                <div class="col-md-6">
                    <p class="mb-2"><strong>Ngày kết thúc:</strong> @Model.Ngayketthuc?.ToString("dd/MM/yyyy")</p>
                    <p class="mb-2"><strong>Trạng thái:</strong> @trangThaiText</p>
                </div>

                <div class="col-12">
                    <p class="mb-1"><strong>Mô tả:</strong></p>
                    <div class="border rounded p-3 bg-light-subtle">
                        @if (string.IsNullOrWhiteSpace(Model.Mota))
                        {
                            <span class="text-muted">(Không có mô tả)</span>
                        }
                        else
                        {
                            @Model.Mota
                        }
                    </div>
                </div>
            </div>

            <hr />

            <form asp-action="Delete">
                <input type="hidden" asp-for="Maduan" />

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
                    <button type="submit" class="btn btn-danger">Xác nhận xóa</button>
                </div>
            </form>
        </div>
    </div>
</div>
