@model IEnumerable<QL_HieuSuat.Models.Dudoanai>
@using System.Globalization

@{
    ViewData["Title"] = "Trung tâm Dự báo AI";

    var isNewMode = (ViewBag.IsNewAIMode as bool?) ?? false;
}

@if (isNewMode)
{
    var summary = ViewBag.NewAISummary;
    var projectRows = ViewBag.NewTaskDelayProjects as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var employeeRows = ViewBag.NewEmployeeRows as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var viCulture = CultureInfo.GetCultureInfo("vi-VN");

    <div class="ai-page">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
            <div>
                <h2 class="mb-1">Dự báo AI</h2>
                <p class="text-muted mb-0">Chế độ AI mới: Linear Regression dự báo trễ hạn và Random Forest phân loại hiệu suất.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="ChayTatCaDuBaoAI" class="btn btn-primary">Chạy 2 mô hình AI mới</a>
                <a asp-action="ChayDuBaoAI" class="btn btn-outline-primary">Chạy dự báo trễ hạn</a>
                <a asp-action="ChayDuBaoNhanVienAI" class="btn btn-outline-success">Chạy xếp loại nhân viên</a>
            </div>
        </div>

        @if (TempData["AI_SUCCESS"] != null)
        {
            <div class="alert alert-success">@TempData["AI_SUCCESS"]</div>
        }

        @if (TempData["AI_ERROR"] != null)
        {
            <div class="alert alert-danger">@TempData["AI_ERROR"]</div>
        }

        <div class="summary-strip mb-4">
            <span><strong>@summary?.TaskCount</strong> công việc được dự báo</span>
            <span><strong class="text-danger">@summary?.HighRiskCount</strong> nguy cơ trễ cao</span>
            <span><strong>@summary?.AverageLateDays</strong> ngày trễ TB</span>
            <span><strong>@summary?.EmployeeClassifiedCount</strong> nhân viên đã xếp loại</span>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center gap-2 flex-wrap">
                <h5 class="mb-0">Linear Regression - Dự báo trễ hạn theo dự án</h5>
                <input id="projectSearchNewAI" class="form-control form-control-sm table-search" placeholder="Tìm dự án..." />
            </div>
            <div class="p-3" id="newAiProjectContainer">
                @if (!projectRows.Any())
                {
                    <div class="text-center text-muted py-4">Chưa có dữ liệu dự báo trễ hạn.</div>
                }
                else
                {
                    foreach (var project in projectRows)
                    {
                        var avgRisk = (double)project.AverageRiskPercent;
                        var riskBadge = avgRisk >= 60 ? "bg-danger" : avgRisk >= 30 ? "bg-warning text-dark" : "bg-success";
                        var riskLabel = avgRisk >= 60 ? "Rủi ro cao" : avgRisk >= 30 ? "Rủi ro trung bình" : "Rủi ro thấp";
                        var avgRiskText = avgRisk.ToString("0.###", viCulture);

                        <details class="border rounded-3 mb-3 project-block" data-project-name="@project.ProjectName">
                            <summary class="p-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div>
                                    <div class="fw-semibold">@project.ProjectName</div>
                                    <div class="small text-muted">Mã dự án: @project.ProjectId</div>
                                </div>
                                <div class="d-flex gap-2 flex-wrap">
                                    <span class="badge bg-secondary">@project.TaskCount công việc</span>
                                    <span class="badge bg-danger">@project.HighRiskTaskCount nguy cơ cao</span>
                                    <span class="badge @riskBadge">@riskLabel @avgRiskText%</span>
                                </div>
                            </summary>

                            <div class="px-3 pb-3 border-top">
                                <div class="row g-2 mt-1 mb-3">
                                    <div class="col-md-4">
                                        <div class="alert alert-warning mb-0">
                                            <div class="fw-semibold mb-1">Nên tăng cường công việc</div>
                                            <div class="small">@project.FocusTasksSuggestion</div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="alert alert-info mb-0">
                                            <div class="fw-semibold mb-1">Gợi ý nhân sự rảnh (KN + kỹ năng)</div>
                                            <div class="small">@project.SupportEmployeesSuggestion</div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="alert alert-primary mb-0">
                                            <div class="fw-semibold mb-1">Gợi ý nhóm rảnh hỗ trợ</div>
                                            <div class="small">@project.SupportGroupsSuggestion</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Công việc</th>
                                                <th>Số ngày trễ dự báo</th>
                                                <th>Xác suất trễ hạn</th>
                                                <th>Khuyến nghị theo công việc</th>
                                                <th>Cập nhật</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var task in project.Tasks)
                                            {
                                                var riskPct = (double)task.LateProbabilityPercent;
                                                var barClass = riskPct >= 60 ? "bg-danger" : riskPct >= 30 ? "bg-warning" : "bg-success";
                                                var riskPctText = riskPct.ToString("0.###", viCulture);

                                                <tr>
                                                    <td>
                                                        <div class="fw-semibold">@task.TaskName</div>
                                                        <div class="small text-muted">Mã: @task.TaskId</div>
                                                    </td>
                                                    <td>@task.PredictedLateDays ngày</td>
                                                    <td style="min-width:200px;">
                                                        <div class="progress ai-progress">
                                                            <div class="progress-bar @barClass" style="width:@riskPct%;">@riskPctText%</div>
                                                        </div>
                                                    </td>
                                                    <td>@task.Suggestion</td>
                                                    <td>@(task.UpdatedAt == null ? "-" : ((DateTime)task.UpdatedAt).ToString("dd/MM/yyyy HH:mm"))</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </details>
                    }
                }
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center gap-2 flex-wrap">
                <h5 class="mb-0">Random Forest - Phân loại và đánh giá hiệu suất nhân viên</h5>
                <input id="employeeSearch" class="form-control form-control-sm table-search" placeholder="Tìm nhân viên..." />
            </div>
            <div class="p-3" id="employeeContainer">
                @if (!employeeRows.Any())
                {
                    <div class="text-center text-muted py-4">Chưa có dữ liệu phân loại nhân viên.</div>
                }
                else
                {
                    foreach (var row in employeeRows)
                    {
                        var confidence = (double)row.ConfidencePercent;
                        var confidenceText = confidence.ToString("0.###", viCulture);
                        var evaluationScore = (double)row.EvaluationScore;
                        var evalText = evaluationScore.ToString("0.###", viCulture);
                        var classification = (string)row.Classification;
                        var badge = classification == "Xuất sắc" ? "bg-success"
                            : classification == "Tốt" ? "bg-primary"
                            : classification == "Trung bình" ? "bg-warning text-dark"
                            : "bg-danger";

                        <details class="border rounded-3 mb-3 employee-block" data-employee-name="@row.EmployeeName">
                            <summary class="p-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div>
                                    <div class="fw-semibold">@row.EmployeeName</div>
                                    <div class="small text-muted">Mã nhân viên: @row.EmployeeId</div>
                                </div>
                                <div class="d-flex gap-2 flex-wrap">
                                    <span class="badge @badge">@classification</span>
                                    <span class="badge bg-dark">Điểm đánh giá @evalText</span>
                                    <span class="badge bg-info text-dark">Tin cậy @confidenceText%</span>
                                </div>
                            </summary>

                            <div class="px-3 pb-3 border-top">
                                <div class="row g-2 mt-1 mb-2">
                                    <div class="col-md-3"><div class="border rounded p-2 small"><strong>Tổng công việc:</strong> @row.TotalTasks</div></div>
                                    <div class="col-md-3"><div class="border rounded p-2 small"><strong>Hoàn thành:</strong> @row.CompletedTasks</div></div>
                                    <div class="col-md-3"><div class="border rounded p-2 small"><strong>Trễ hạn:</strong> @row.OverdueTasks</div></div>
                                    <div class="col-md-3"><div class="border rounded p-2 small"><strong>Dự án tham gia:</strong> @row.ParticipatedProjectCount</div></div>
                                    <div class="col-md-3"><div class="border rounded p-2 small"><strong>Tỷ lệ hoàn thành:</strong> @(((double)row.CompletionRatePercent).ToString("0.###", viCulture))%</div></div>
                                    <div class="col-md-3"><div class="border rounded p-2 small"><strong>Tỷ lệ trễ hạn:</strong> @(((double)row.OverdueRatePercent).ToString("0.###", viCulture))%</div></div>
                                    <div class="col-md-3"><div class="border rounded p-2 small"><strong>KPI gần nhất:</strong> @(((double)row.LatestKpi).ToString("0.###", viCulture))</div></div>
                                    <div class="col-md-3"><div class="border rounded p-2 small"><strong>Kinh nghiệm:</strong> @(((double)row.ExperienceYears).ToString("0.###", viCulture)) năm</div></div>
                                    <div class="col-md-3"><div class="border rounded p-2 small text-success"><strong>Điểm cộng:</strong> @(((double)row.BonusPoints).ToString("0.###", viCulture))</div></div>
                                    <div class="col-md-3"><div class="border rounded p-2 small text-danger"><strong>Điểm trừ:</strong> @(((double)row.PenaltyPoints).ToString("0.###", viCulture))</div></div>
                                    <div class="col-md-6"><div class="border rounded p-2 small"><strong>Mức ảnh hưởng yếu tố KPI:</strong> @(string.IsNullOrWhiteSpace((string?)row.FeatureImpact) ? "Chưa có phân tích" : row.FeatureImpact)</div></div>
                                    <div class="col-md-3"><div class="border rounded p-2 small"><strong>Cập nhật:</strong> @(row.UpdatedAt == null ? "-" : ((DateTime)row.UpdatedAt).ToString("dd/MM/yyyy HH:mm"))</div></div>
                                </div>
                            </div>
                        </details>
                    }
                }
            </div>
        </div>
    </div>
}
else
{
    var projectNames = ViewBag.ProjectNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var projectEstimatedDates = ViewBag.ProjectEstimatedDates as Dictionary<int, DateTime?> ?? new Dictionary<int, DateTime?>();
    var projectDeadlines = ViewBag.ProjectDeadlines as Dictionary<int, DateTime?> ?? new Dictionary<int, DateTime?>();
    var projectSkillSuggestions = ViewBag.ProjectSkillSuggestions as Dictionary<int, string> ?? new Dictionary<int, string>();

    var projectLatest = Model
        .Where(x => x.Madoituong.HasValue)
        .GroupBy(x => x.Madoituong!.Value)
        .Select(g => g
            .OrderByDescending(x => x.Nam ?? 0)
            .ThenByDescending(x => x.Thang ?? 0)
            .ThenByDescending(x => x.Thoigiandudoan ?? DateTime.MinValue)
            .First())
        .OrderByDescending(x => x.Xacsuattrehan ?? 0)
        .ToList();

    var employeeLatest = Model
        .Where(x => x.Manhanvien.HasValue)
        .GroupBy(x => x.Manhanvien!.Value)
        .Select(g => g
            .OrderByDescending(x => x.Nam ?? 0)
            .ThenByDescending(x => x.Thang ?? 0)
            .ThenByDescending(x => x.Thoigiandudoan ?? DateTime.MinValue)
            .First())
        .OrderByDescending(x => x.Diemdudoan ?? 0)
        .ToList();

    int totalProjects = projectLatest.Count;
    int highRisk = projectLatest.Count(x => (x.Xacsuattrehan ?? 0) > 0.6);
    int mediumRisk = projectLatest.Count(x => (x.Xacsuattrehan ?? 0) > 0.3 && (x.Xacsuattrehan ?? 0) <= 0.6);
    int stable = totalProjects - highRisk - mediumRisk;
    var avgRisk = totalProjects == 0 ? 0 : projectLatest.Average(x => (x.Xacsuattrehan ?? 0) * 100);

    <div class="ai-page">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
            <div>
                <h2 class="mb-1">Dự báo AI</h2>
                <p class="text-muted mb-0">Chế độ Legacy đang được bật.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="ChayTatCaDuBaoAI" class="btn btn-primary">Chạy toàn bộ AI</a>
            </div>
        </div>

        @if (TempData["AI_SUCCESS"] != null)
        {
            <div class="alert alert-success">@TempData["AI_SUCCESS"]</div>
        }

        @if (TempData["AI_ERROR"] != null)
        {
            <div class="alert alert-danger">@TempData["AI_ERROR"]</div>
        }

        <div class="summary-strip mb-4">
            <span><strong>@totalProjects</strong> dự án</span>
            <span><strong class="text-danger">@highRisk</strong> nguy cơ cao</span>
            <span><strong class="text-warning">@mediumRisk</strong> trung bình</span>
            <span><strong class="text-success">@stable</strong> ổn định</span>
            <span><strong>@Math.Round(avgRisk, 1)%</strong> rủi ro TB</span>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center gap-2 flex-wrap">
                <h5 class="mb-0">Dự báo dự án (bản ghi mới nhất)</h5>
                <input id="projectSearch" class="form-control form-control-sm table-search" placeholder="Tìm nhanh..." />
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="projectTable">
                    <thead class="table-light">
                        <tr>
                            <th>Dự án</th>
                            <th>Kỳ</th>
                            <th>Hạn hoàn thành</th>
                            <th>Dự kiến hoàn thành</th>
                            <th>Xác suất trễ hạn</th>
                            <th>Khuyến nghị</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!projectLatest.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Chưa có dữ liệu dự báo dự án.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in projectLatest)
                            {
                                var projectId = item.Madoituong ?? 0;
                                var projectLabel = projectNames.TryGetValue(projectId, out var tenDuAn)
                                    ? tenDuAn
                                    : $"Dự án #{projectId}";
                                var estimatedDate = projectEstimatedDates.TryGetValue(projectId, out var ngayDuKien) ? ngayDuKien : null;
                                var deadlineDate = projectDeadlines.TryGetValue(projectId, out var ngayHan) ? ngayHan : null;
                                var skillSuggestion = projectSkillSuggestions.TryGetValue(projectId, out var goiYNhanSu)
                                    ? goiYNhanSu
                                    : "Chưa có gợi ý nhân sự theo kỹ năng.";
                                var riskPct = Math.Round((item.Xacsuattrehan ?? 0) * 100, 1);
                                var barClass = riskPct > 60 ? "bg-danger" : riskPct > 30 ? "bg-warning" : "bg-success";

                                <tr>
                                    <td>
                                        <div class="fw-semibold">@projectLabel</div>
                                        <div class="small text-muted">Mã: @item.Madoituong</div>
                                    </td>
                                    <td>@item.Thang/@item.Nam</td>
                                    <td>@(deadlineDate.HasValue ? deadlineDate.Value.ToString("dd/MM/yyyy") : "Chưa thiết lập")</td>
                                    <td>@(estimatedDate.HasValue ? estimatedDate.Value.ToString("dd/MM/yyyy") : "Chưa đủ dữ liệu")</td>
                                    <td style="min-width: 200px;">
                                        <div class="progress ai-progress">
                                            <div class="progress-bar @barClass" style="width:@riskPct%;">@riskPct%</div>
                                        </div>
                                    </td>
                                    <td>
                                        <div>@(string.IsNullOrWhiteSpace(item.Dexuatcaithien) ? "Không có" : item.Dexuatcaithien)</div>
                                        <div class="small text-muted mt-1">Gợi ý nhân sự: @skillSuggestion</div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center gap-2 flex-wrap">
                <h5 class="mb-0">Dự báo KPI nhân viên (bản ghi mới nhất)</h5>
                <input id="employeeSearch" class="form-control form-control-sm table-search" placeholder="Tìm nhanh..." />
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="employeeTable">
                    <thead class="table-light">
                        <tr>
                            <th>Nhân viên</th>
                            <th>Điểm KPI</th>
                            <th>Gợi ý</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!employeeLatest.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">Chưa có dữ liệu dự báo nhân viên.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in employeeLatest)
                            {
                                var score = Math.Round(item.Diemdudoan ?? 0, 1);
                                var barClass = score < 60 ? "bg-danger" : score < 75 ? "bg-warning" : "bg-success";
                                var displayName = item.ManhanvienNavigation?.Hoten ?? $"Nhân viên #{item.Manhanvien}";

                                <tr>
                                    <td>
                                        <div class="fw-semibold">@displayName</div>
                                        <div class="small text-muted">Mã: @item.Manhanvien</div>
                                    </td>
                                    <td style="min-width: 180px;">
                                        <div class="progress ai-progress">
                                            <div class="progress-bar @barClass" style="width:@score%;">@score</div>
                                        </div>
                                    </td>
                                    <td>@(string.IsNullOrWhiteSpace(item.Gioiynguonluc) ? "Khong co" : item.Gioiynguonluc)</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<script>
    function wireTableSearch(inputId, tableId) {
        const input = document.getElementById(inputId);
        const table = document.getElementById(tableId);
        if (!input || !table) return;

        input.addEventListener("input", function () {
            const q = this.value.toLowerCase().trim();
            const rows = table.querySelectorAll("tbody tr");

            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                row.style.display = text.includes(q) ? "" : "none";
            });
        });
    }

    const projectSearchNewAI = document.getElementById("projectSearchNewAI");
    const newAiProjectContainer = document.getElementById("newAiProjectContainer");
    if (projectSearchNewAI && newAiProjectContainer) {
        projectSearchNewAI.addEventListener("input", function () {
            const q = this.value.toLowerCase().trim();
            const blocks = newAiProjectContainer.querySelectorAll(".project-block");

            blocks.forEach(block => {
                const projectName = (block.getAttribute("data-project-name") || "").toLowerCase();
                block.style.display = projectName.includes(q) ? "" : "none";
            });
        });
    }

    wireTableSearch("projectSearch", "projectTable");

    const employeeSearch = document.getElementById("employeeSearch");
    const employeeContainer = document.getElementById("employeeContainer");
    const employeeTable = document.getElementById("employeeTable");

    if (employeeSearch && employeeContainer) {
        employeeSearch.addEventListener("input", function () {
            const q = this.value.toLowerCase().trim();
            const blocks = employeeContainer.querySelectorAll(".employee-block");

            blocks.forEach(block => {
                const employeeName = (block.getAttribute("data-employee-name") || "").toLowerCase();
                block.style.display = employeeName.includes(q) ? "" : "none";
            });
        });
    } else if (employeeSearch && employeeTable) {
        wireTableSearch("employeeSearch", "employeeTable");
    }
</script>
