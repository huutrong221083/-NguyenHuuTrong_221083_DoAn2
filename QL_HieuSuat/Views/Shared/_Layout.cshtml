@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hệ thống quản lý hiệu suất</title>

        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
        <link rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">
        <link rel="stylesheet" href="~/css/site.css" />

</head>

<body class="app-body">

    @if (SignInManager.IsSignedIn(User))
    {
        var isAdmin = User.IsInRole("Admin");
        var currentUser = await UserManager.GetUserAsync(User);
        var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty).Trim();
        var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty).Trim();
        var pageTitle = (ViewData["Title"]?.ToString() ?? currentController).Trim();

        var displayName = currentUser?.Nhanvien?.Hoten;
        if (string.IsNullOrWhiteSpace(displayName) && currentUser?.MaNhanVien is int maNhanVien)
        {
            displayName = await DbContext.Nhanviens
                .AsNoTracking()
                .Where(nv => nv.Manhanvien == maNhanVien)
                .Select(nv => nv.Hoten)
                .FirstOrDefaultAsync();
        }

        displayName = string.IsNullOrWhiteSpace(displayName)
            ? (User.Identity?.Name ?? "Người dùng")
            : displayName;

        var roles = currentUser is null
            ? new List<string>()
            : (await UserManager.GetRolesAsync(currentUser)).ToList();

        var roleDisplayMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["Admin"] = "Quản trị viên",
            ["QuanLyNhanSu"] = "Quản lý nhân sự",
            ["QuanLyPhongBan"] = "Quản lý phòng ban",
            ["TruongPhong"] = "Trưởng phòng",
            ["TruongNhom"] = "Trưởng nhóm",
            ["NhanVien"] = "Nhân viên"
        };

        var rolePriority = new[]
        {
            "Admin",
            "QuanLyNhanSu",
            "QuanLyPhongBan",
            "TruongPhong",
            "TruongNhom",
            "NhanVien"
        };

        var roleToShow = rolePriority.FirstOrDefault(priorityRole => roles.Contains(priorityRole))
            ?? roles.FirstOrDefault();
        var displayRole = !string.IsNullOrWhiteSpace(roleToShow)
            ? (roleDisplayMap.TryGetValue(roleToShow, out var mappedRole) ? mappedRole : roleToShow)
            : "Người dùng";

        var controllerDisplayNames = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["Admin"] = "Quản trị",
            ["Account"] = "Tài khoản",
            ["Home"] = "Trang chủ",
            ["Nhanviens"] = "Nhân viên",
            ["NhanVien"] = "Nhân viên",
            ["Phongbans"] = "Phòng ban",
            ["Duans"] = "Dự án",
            ["Nhoms"] = "Nhóm",
            ["Congviecs"] = "Công việc",
            ["ThongKe"] = "Thống kê",
            ["Dudoanais"] = "Dự báo AI",
            ["Phancongcongviecs"] = "Phân công công việc",
            ["QuanLyNhanSu"] = "Quản lý nhân sự",
            ["QuanLyPhongBan"] = "Quản lý phòng ban"
        };

        var actionDisplayNames = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["Index"] = "Danh sách",
            ["Create"] = "Thêm mới",
            ["Edit"] = "Chỉnh sửa",
            ["Delete"] = "Xóa",
            ["Details"] = "Chi tiết",
            ["Login"] = "Đăng nhập",
            ["Logout"] = "Đăng xuất",
            ["ThongTinVaXepLoai"] = "Thông tin cá nhân và xếp loại",
            ["DuAnCongViecDangThamGia"] = "Dự án/công việc đang tham gia",
            ["DuAnDaThamGia"] = "Dự án đã tham gia",
            ["DanhGiaCaNhan"] = "Xem đánh giá cá nhân",
            ["ThongTinDonViPhuTrach"] = "Thông tin nhóm/phòng phụ trách",
            ["DanhGiaDonViQuanLy"] = "Đánh giá nhóm/phòng quản lý",
            ["YeuCauChinhSuaThongTin"] = "Yêu cầu chỉnh sửa thông tin"
        };

        var controllerDisplayName = controllerDisplayNames.TryGetValue(currentController, out var ctlName)
            ? ctlName
            : currentController;
        var actionDisplayName = actionDisplayNames.TryGetValue(currentAction, out var actName)
            ? actName
            : currentAction;

        <div class="app-shell d-flex">

            <!-- SIDEBAR -->

            <aside class="app-sidebar bg-dark text-white p-3">

                <div class="app-brand mb-4">
                    <div class="app-brand-logo">QL</div>
                    <div>
                        <div class="app-brand-title">Hệ thống hiệu suất</div>
                        
                    </div>
                </div>

                <ul class="nav flex-column">
                    @if (isAdmin)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Admin" asp-action="Index">
                                <i class="bi bi-speedometer2"></i> Tổng quát
                            </a>
                        </li>

                        <li class="nav-item mt-3 text-secondary small">
                            QUẢN LÝ
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Nhanviens" asp-action="Index">
                                <i class="bi bi-people"></i> QL Nhân viên
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Admin" asp-action="TaoTaiKhoan">
                                <i class="bi bi-person-plus"></i> Tạo tài khoản
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Admin" asp-action="DanhSachTaiKhoan">
                                <i class="bi bi-person-lines-fill"></i> Danh sách tài khoản
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Phongbans" asp-action="Index">
                                <i class="bi bi-building"></i> QL Phòng ban
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Duans" asp-action="Index">
                                <i class="bi bi-folder"></i> QL Dự án
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Nhoms" asp-action="Index">
                                <i class="bi bi-diagram-3"></i> QL Nhóm
                            </a>
                        </li>

                        <li class="nav-item mt-3 text-secondary small">
                            HIỆU SUẤT HOẠT ĐỘNG
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="ThongKe" asp-action="Index">
                                <i class="bi bi-bar-chart"></i> Thống kê
                            </a>
                        </li>

                        

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Dudoanais" asp-action="Index">
                                <i class="bi bi-robot"></i> Dự báo AI
                            </a>
                        </li>
                    }
                    else
                    {
                        var isHrManager = User.IsInRole("QuanLyNhanSu");
                        var isDepartmentHead = User.IsInRole("TruongPhong");
                        var isDepartmentManager = User.IsInRole("QuanLyPhongBan");
                        var isTeamLead = User.IsInRole("TruongNhom");

                        @if (isHrManager)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="QuanLyNhanSu" asp-action="ThongTinVaXepLoai">
                                    <i class="bi bi-person-badge"></i> Thông tin cá nhân và xếp loại
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="QuanLyNhanSu" asp-action="Index">
                                    <i class="bi bi-people-fill"></i> Quản lý nhân viên
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="QuanLyNhanSu" asp-action="DanhGiaCaNhan">
                                    <i class="bi bi-graph-up"></i> Xem đánh giá cá nhân
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="QuanLyNhanSu" asp-action="YeuCauChinhSuaThongTin">
                                    <i class="bi bi-pencil-square"></i> Yêu cầu chỉnh sửa thông tin
                                </a>
                            </li>
                        }

                        @if (isDepartmentManager)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Phongbans" asp-action="Index">
                                    <i class="bi bi-list-ul"></i> Danh sách phòng ban
                                </a>
                            </li>
                        }

                        @if (isDepartmentHead)
                        {
                            <li class="nav-item mt-3 text-secondary small">
                                QUẢN LÝ PHÒNG
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="NhanVien" asp-action="ThongTinDonViPhuTrach">
                                    <i class="bi bi-building"></i> Thông tin phòng đang phụ trách
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="NhanVien" asp-action="DanhGiaDonViQuanLy">
                                    <i class="bi bi-bar-chart"></i> Xem đánh giá phòng quản lý
                                </a>
                            </li>
                        }

                        @if (isTeamLead)
                        {
                            <li class="nav-item mt-3 text-secondary small">
                                QUẢN LÝ NHÓM
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="NhanVien" asp-action="ThongTinDonViPhuTrach">
                                    <i class="bi bi-diagram-3"></i> Thông tin nhóm đang phụ trách
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="NhanVien" asp-action="DanhGiaDonViQuanLy">
                                    <i class="bi bi-graph-up-arrow"></i> Xem đánh giá nhóm quản lý
                                </a>
                            </li>
                        }

                        @if (isDepartmentHead || isTeamLead)
                        {
                            <li class="nav-item mt-3 text-secondary small">
                                CÔNG VIỆC CÁ NHÂN
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="NhanVien" asp-action="DuAnCongViecDangThamGia">
                                    <i class="bi bi-kanban"></i> Dự án/công việc đang tham gia
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="NhanVien" asp-action="DuAnDaThamGia">
                                    <i class="bi bi-folder-check"></i> Dự án/công việc đã tham gia
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="NhanVien" asp-action="ThongTinVaXepLoai">
                                    <i class="bi bi-person-vcard"></i> Thông tin cá nhân và xếp loại
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Congviecs" asp-action="XacNhanTienDo">
                                    <i class="bi bi-check2-square"></i> Duyệt tiến độ
                                </a>
                            </li>
                        }

                        @if (isDepartmentManager)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Congviecs" asp-action="Index">
                                    <i class="bi bi-diagram-3"></i> Chọn công việc để giao
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Congviecs" asp-action="XacNhanTienDo">
                                    <i class="bi bi-check2-square"></i> Duyệt tiến độ
                                </a>
                            </li>
                        }

                        @if (!isHrManager && !isDepartmentHead && !isDepartmentManager && !isTeamLead)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="NhanVien" asp-action="ThongTinVaXepLoai">
                                    <i class="bi bi-person-vcard"></i> Thông tin cá nhân và xếp loại
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="NhanVien" asp-action="DuAnCongViecDangThamGia">
                                    <i class="bi bi-kanban"></i> Dự án/công việc đang tham gia
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="NhanVien" asp-action="DuAnDaThamGia">
                                    <i class="bi bi-folder-check"></i> Dự án đã tham gia
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="NhanVien" asp-action="DanhGiaCaNhan">
                                    <i class="bi bi-graph-up-arrow"></i> Xem đánh giá cá nhân
                                </a>
                            </li>
                        }
                    }

                </ul>

            </aside>

            <div class="app-sidebar-backdrop" id="appSidebarBackdrop"></div>


            <!-- MAIN CONTENT -->

            <main class="main-content app-main flex-grow-1">

                <!-- TOPBAR -->

                <nav class="navbar navbar-light bg-light shadow-sm px-4 topbar app-topbar">

                    <div class="d-flex align-items-center gap-3">
                        <button class="btn btn-outline-secondary btn-sm d-lg-none"
                                type="button"
                                id="sidebarToggle"
                                aria-label="Mở menu">
                            <i class="bi bi-list"></i>
                        </button>

                        <div class="app-topbar-title-wrap">
                            <div class="app-topbar-title">@pageTitle</div>
                            <div class="app-topbar-meta">@controllerDisplayName / @actionDisplayName</div>
                        </div>
                    </div>

                    <div class="ms-auto d-flex align-items-center">

                        <span class="me-3">
                            Xin chào <strong>@displayName</strong> - <span class="text-muted">@displayRole</span>
                        </span>

                        <a class="btn btn-outline-danger btn-sm"
                           asp-controller="Account"
                           asp-action="Logout">
                            Đăng xuất
                        </a>

                    </div>

                </nav>


                <!-- PAGE CONTENT -->

                <div class="page-content app-page-content">

                    <div class="app-content-wrap">
                        @RenderBody()
                    </div>

                </div>

            </main>

        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>

    <script>
        (function () {
            const currentPath = (window.location.pathname || "").toLowerCase();
            const navLinks = document.querySelectorAll(".app-sidebar .nav-link[href]");

            navLinks.forEach(link => {
                const href = (link.getAttribute("href") || "").toLowerCase();
                if (!href || href === "#") return;

                if (currentPath === href || (href !== "/" && currentPath.startsWith(href))) {
                    link.classList.add("active");
                }
            });

            const body = document.body;
            const sidebarToggle = document.getElementById("sidebarToggle");
            const backdrop = document.getElementById("appSidebarBackdrop");

            function closeSidebar() {
                body.classList.remove("sidebar-open");
            }

            function openSidebar() {
                body.classList.add("sidebar-open");
            }

            if (sidebarToggle) {
                sidebarToggle.addEventListener("click", function () {
                    if (body.classList.contains("sidebar-open")) {
                        closeSidebar();
                    } else {
                        openSidebar();
                    }
                });
            }

            if (backdrop) {
                backdrop.addEventListener("click", closeSidebar);
            }

            navLinks.forEach(link => link.addEventListener("click", closeSidebar));

            if (window.jQuery && window.jQuery.validator) {
                window.jQuery.extend(window.jQuery.validator.messages, {
                    required: "Trường này là bắt buộc.",
                    remote: "Vui lòng sửa trường này.",
                    email: "Địa chỉ email không hợp lệ.",
                    url: "Đường dẫn không hợp lệ.",
                    date: "Ngày không hợp lệ.",
                    dateISO: "Ngày không hợp lệ (yyyy-mm-dd).",
                    number: "Vui lòng nhập số hợp lệ.",
                    digits: "Chỉ được nhập chữ số.",
                    creditcard: "Số thẻ không hợp lệ.",
                    equalTo: "Giá trị nhập lại không khớp.",
                    maxlength: window.jQuery.validator.format("Vui lòng không nhập quá {0} ký tự."),
                    minlength: window.jQuery.validator.format("Vui lòng nhập ít nhất {0} ký tự."),
                    rangelength: window.jQuery.validator.format("Vui lòng nhập từ {0} đến {1} ký tự."),
                    range: window.jQuery.validator.format("Giá trị phải nằm trong khoảng từ {0} đến {1}.") ,
                    max: window.jQuery.validator.format("Giá trị phải nhỏ hơn hoặc bằng {0}."),
                    min: window.jQuery.validator.format("Giá trị phải lớn hơn hoặc bằng {0}.")
                });
            }

            // Add required marker and validate fields immediately after user input ends.
            const forms = document.querySelectorAll("form");
            forms.forEach(form => {
                form.querySelectorAll("input, select, textarea").forEach(input => {
                    const hasRequired =
                        input.hasAttribute("required") ||
                        input.getAttribute("data-val-required") !== null;

                    if (hasRequired && input.id) {
                        const label = form.querySelector(`label[for="${input.id}"]`);
                        if (label && !label.querySelector(".required-star")) {
                            const mark = document.createElement("span");
                            mark.className = "required-star text-danger ms-1";
                            mark.textContent = "*";
                            label.appendChild(mark);
                        }
                    }

                    const isNumeric = input.type === "number" || input.getAttribute("data-val-number") !== null;
                    if (isNumeric && !input.getAttribute("inputmode")) {
                        input.setAttribute("inputmode", "decimal");
                    }
                });

                if (window.jQuery) {
                    const $form = window.jQuery(form);
                    $form.find("input, select, textarea").on("blur change input", function () {
                        if ($form.data("validator")) {
                            window.jQuery(this).valid();
                        }
                    });
                }
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>