@model QL_HieuSuat.Models.ViewModels.SuaTaiKhoanViewModel

@{
    ViewData["Title"] = "Chỉnh sửa tài khoản";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow">
                <div class="card-header bg-warning">
                    <h5 class="mb-0">Chỉnh sửa tài khoản</h5>
                </div>
                <div class="card-body">
                    <form asp-action="SuaTaiKhoan" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="UserId" type="hidden" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MaNhanVien" class="form-label">Nhân viên liên kết</label>
                            <select asp-for="MaNhanVien" class="form-select" asp-items="ViewBag.NhanVienOptions"></select>
                            <span asp-validation-for="MaNhanVien" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Role" class="form-label">Vai trò</label>
                            <select asp-for="Role" class="form-select" asp-items="ViewBag.RoleOptions"></select>
                            <span asp-validation-for="Role" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Lưu thay đổi</button>
                            <a asp-action="DanhSachTaiKhoan" class="btn btn-outline-secondary">Quay lại danh sách</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
