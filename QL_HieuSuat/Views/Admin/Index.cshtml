@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Hệ thống quản lý hiệu suất";

    var top = ViewBag.TopNhanVien as IEnumerable<dynamic>;
    var tre = ViewBag.CongViecTre as IEnumerable<dynamic>;
    var sapTre = ViewBag.CongViecSapTre as IEnumerable<dynamic>;
    var tb = ViewBag.ThongBaoMoi as IEnumerable<dynamic>;

    var soTre = tre?.Count() ?? 0;
    var soSapTre = sapTre?.Count() ?? 0;
}

<div class="container-fluid admin-overview-page">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
        <div>
            <h3 class="fw-bold mb-1">Dashboard Tổng Quan Hệ Thống</h3>
            <div class="text-muted">Tập trung vào các chỉ số quan trọng và cảnh báo cần xử lý ngay.</div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="text-muted mb-1">Tổng nhân viên</div>
                    <div class="display-6 fw-bold text-primary">@(ViewBag.TotalNhanVien ?? 0)</div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="text-muted mb-1">Đánh giá KPI</div>
                    <div class="display-6 fw-bold text-success">@(ViewBag.TotalKPI ?? 0)</div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="text-muted mb-1">Hiệu suất trung bình</div>
                    <div class="display-6 fw-bold text-danger">@(ViewBag.AvgKPI ?? 0)%</div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 alert-kpi-card">
                <div class="card-body">
                    <div class="text-muted mb-1">Cảnh báo công việc</div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="badge bg-danger">Trễ: @soTre</span>
                        <span class="badge bg-warning text-dark">Sắp trễ: @soSapTre</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <h5 class="mb-3">Top 5 Nhân Viên Hiệu Suất Cao</h5>
                    <div class="table-responsive fixed-overview-table">
                        <table class="table table-sm table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:72px;">STT</th>
                                    <th>Nhân viên</th>
                                    <th style="width:140px;">Điểm KPI</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int stt = 1; }
                                @if (top != null)
                                {
                                    foreach (var nv in top)
                                    {
                                        <tr>
                                            <td>@stt</td>
                                            <td class="fw-semibold">@nv.Ten</td>
                                            <td>@Math.Round(nv.Diem, 2)</td>
                                        </tr>
                                        stt++;
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <h5 class="mb-3">Thông Báo Hệ Thống</h5>
                    <div class="list-group fixed-overview-list">
                        @if (tb != null && tb.Any())
                        {
                            foreach (var t in tb)
                            {
                                <div class="list-group-item d-flex justify-content-between gap-3">
                                    <span>@t.NoiDung</span>
                                    <small class="text-muted text-nowrap">@t.ThoiGian.ToString("dd/MM HH:mm")</small>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="list-group-item text-muted">Chưa có thông báo mới.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <h5 class="text-danger mb-3">Công Việc Đã Trễ Hạn</h5>
                    <div class="table-responsive fixed-overview-table">
                        <table class="table table-sm table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Công việc</th>
                                    <th style="width:130px;">Hạn</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (tre != null && tre.Any())
                                {
                                    foreach (var cv in tre)
                                    {
                                        <tr>
                                            <td>@cv.Ten</td>
                                            <td>@(cv.Han == null ? "-" : ((DateTime)cv.Han).ToString("dd/MM/yyyy"))</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="2" class="text-muted">Không có công việc trễ hạn.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <h5 class="text-warning mb-3">Công Việc Sắp Trễ (3 ngày)</h5>
                    <div class="table-responsive fixed-overview-table">
                        <table class="table table-sm table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Công việc</th>
                                    <th style="width:130px;">Hạn</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (sapTre != null && sapTre.Any())
                                {
                                    foreach (var cv in sapTre)
                                    {
                                        <tr>
                                            <td>@cv.Ten</td>
                                            <td>@(cv.Han == null ? "-" : ((DateTime)cv.Han).ToString("dd/MM/yyyy"))</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="2" class="text-muted">Không có công việc sắp trễ.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-overview-page .fixed-overview-table {
        max-height: 260px;
        overflow-y: auto;
    }

    .admin-overview-page .fixed-overview-list {
        max-height: 260px;
        overflow-y: auto;
    }

    .admin-overview-page .fixed-overview-table thead th {
        position: sticky;
        top: 0;
        z-index: 1;
        background: #f8f9fa;
    }

    .admin-overview-page .alert-kpi-card {
        border-left: 4px solid #f59e0b;
    }
</style>