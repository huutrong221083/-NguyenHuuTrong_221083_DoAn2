@model QL_HieuSuat.Models.ViewModels.NhanVienThongTinXepLoaiViewModel

@{
    ViewData["Title"] = "Thông tin cá nhân và xếp loại";
    var nv = Model.HoSoNhanVien;
    var tenPhongBan = nv.MaphongbanNavigation?.Tenphongban ?? "Chưa cập nhật";
    var ngaySinh = nv.Ngaysinh?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật";
    var ngayVaoLam = nv.Ngayvaolam?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật";
    var gioiTinh = string.IsNullOrWhiteSpace(nv.Gioitinh) ? "Chưa cập nhật" : nv.Gioitinh;
    var cccd = string.IsNullOrWhiteSpace(nv.Cccd) ? "Chưa cập nhật" : nv.Cccd;
    var sdt = string.IsNullOrWhiteSpace(nv.Sdt) ? "Chưa cập nhật" : nv.Sdt;
    var diaChi = string.IsNullOrWhiteSpace(nv.Diachi) ? "Chưa cập nhật" : nv.Diachi;
    var email = string.IsNullOrWhiteSpace(nv.Email) ? "Chưa cập nhật" : nv.Email;

    var tenNhom = nv.Thanhviennhoms?
        .Select(tv => tv.ManhomNavigation?.Tennhom)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct()
        .ToList() ?? new List<string?>();

    var kyNangs = nv.Kynangnhanviens?
        .Where(kn => !string.IsNullOrWhiteSpace(kn.MakynangNavigation?.Tenkynang))
        .OrderByDescending(kn => kn.Capdo ?? 0)
        .ThenBy(kn => kn.MakynangNavigation!.Tenkynang)
        .ToList() ?? new List<QL_HieuSuat.Models.Kynangnhanvien>();

    var xepLoaiBadge = Model.XepLoaiGanNhat switch
    {
        "Xuất sắc" => "bg-success",
        "Tốt" => "bg-primary",
        "Khá" => "bg-info text-dark",
        "Trung bình" => "bg-warning text-dark",
        "Cần cải thiện" => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="container-fluid">
    <div class="mb-4 p-4 rounded-3 text-white" style="background: linear-gradient(135deg, #198754 0%, #0f5132 100%);">
        <h3 class="mb-1">Thông tin cá nhân và xếp loại</h3>
        <p class="mb-0 opacity-75">Theo dõi hồ sơ nhân viên và kết quả đánh giá gần nhất.</p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-4 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Kỳ đánh giá gần nhất</div>
                    <div class="fw-semibold">@(Model.KyDanhGiaGanNhat ?? "Chưa có dữ liệu")</div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Điểm tổng hợp gần nhất</div>
                    <div class="fs-3 fw-bold">@(Model.DiemDanhGiaGanNhat?.ToString("0.##") ?? "-")</div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-12">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Xếp loại</div>
                    <span class="badge @xepLoaiBadge fs-6">@Model.XepLoaiGanNhat</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">Hồ sơ nhân viên</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="text-muted small">Mã nhân viên</div>
                    <div class="fw-semibold">@nv.Manhanvien</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Họ tên</div>
                    <div class="fw-semibold">@(string.IsNullOrWhiteSpace(nv.Hoten) ? "Chưa cập nhật" : nv.Hoten)</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Email</div>
                    <div class="fw-semibold">@email</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Số điện thoại</div>
                    <div class="fw-semibold">@sdt</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Giới tính</div>
                    <div class="fw-semibold">@gioiTinh</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Ngày sinh</div>
                    <div class="fw-semibold">@ngaySinh</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">CCCD</div>
                    <div class="fw-semibold">@cccd</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Ngày vào làm</div>
                    <div class="fw-semibold">@ngayVaoLam</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Phòng ban</div>
                    <div class="fw-semibold">@tenPhongBan</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Số năm kinh nghiệm</div>
                    <div class="fw-semibold">@(nv.Sonamkinhnghiem?.ToString("0.##") ?? "Chưa cập nhật")</div>
                </div>
                <div class="col-12">
                    <div class="text-muted small">Địa chỉ</div>
                    <div class="fw-semibold">@diaChi</div>
                </div>
                <div class="col-12">
                    <div class="text-muted small mb-1">Nhóm tham gia</div>
                    @if (tenNhom.Any())
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var nhom in tenNhom)
                            {
                                <span class="badge bg-secondary">@nhom</span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">Chưa tham gia nhóm nào.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">Chi tiết đánh giá kỳ gần nhất</h5>
        </div>
        <div class="card-body">
            @if (Model.ChiTietDanhGiaGanNhat.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Danh mục KPI</th>
                                <th width="160">Điểm</th>
                                <th width="160">Trọng số</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ChiTietDanhGiaGanNhat)
                            {
                                <tr>
                                    <td>@(string.IsNullOrWhiteSpace(item.TenDanhMuc) ? "-" : item.TenDanhMuc)</td>
                                    <td>@(item.DiemSo?.ToString("0.##") ?? "-")</td>
                                    <td>@(item.TrongSo?.ToString("0.##") ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-muted">Chưa có dữ liệu đánh giá KPI.</div>
            }
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0">Kỹ năng</h5>
        </div>
        <div class="card-body">
            @if (kyNangs.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Tên kỹ năng</th>
                                <th width="120">Cấp độ</th>
                                <th width="220">Số dự án đã dùng</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kyNang in kyNangs)
                            {
                                <tr>
                                    <td>@kyNang.MakynangNavigation?.Tenkynang</td>
                                    <td>@(kyNang.Capdo?.ToString() ?? "-")</td>
                                    <td>@(kyNang.Soduandadungkynangnay?.ToString() ?? "0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-muted">Chưa cập nhật kỹ năng.</div>
            }
        </div>
    </div>
</div>
