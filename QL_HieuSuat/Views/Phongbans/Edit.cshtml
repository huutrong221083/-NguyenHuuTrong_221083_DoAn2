@model QL_HieuSuat.Models.Phongban

@{
    ViewData["Title"] = "Chỉnh sửa phòng ban";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">✏️ Chỉnh sửa phòng ban</h5>
        </div>

        <div class="card-body">

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="Maphongban" />

                <div class="row">

                    <div class="col-md-6">

                        <div class="mb-3">
                            <label asp-for="Tenphongban" class="form-label fw-semibold">Tên phòng ban</label>
                            <input asp-for="Tenphongban" class="form-control"
                                   placeholder="Nhập tên phòng ban..." />
                            <span asp-validation-for="Tenphongban" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Matruongphong" class="form-label fw-semibold">Trưởng phòng</label>
                            <select asp-for="Matruongphong"
                                    class="form-select"
                                    asp-items="ViewBag.Matruongphong">
                                <option value="">-- Chọn trưởng phòng --</option>
                            </select>
                            <span asp-validation-for="Matruongphong" class="text-danger"></span>
                        </div>

                    </div>

                    <div class="col-md-6">

                        <div class="mb-3">
                            <label asp-for="Mota" class="form-label fw-semibold">Mô tả</label>
                            <textarea asp-for="Mota"
                                      class="form-control"
                                      rows="5"
                                      placeholder="Nhập mô tả phòng ban..."></textarea>
                            <span asp-validation-for="Mota" class="text-danger"></span>
                        </div>

                    </div>

                </div>

                <div class="mt-4 d-flex justify-content-between">

                    <a asp-action="Index" class="btn btn-secondary">
                        ⬅ Quay lại
                    </a>

                    <div>

                        <a asp-controller="Nhanviens"
                           asp-action="AddToPhong"
                           asp-route-maphongban="@Model.Maphongban"
                           class="btn btn-success me-2">
                            ➕ Thêm nhân viên
                        </a>

                        <button type="submit" class="btn btn-primary">
                            💾 Lưu thay đổi
                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}