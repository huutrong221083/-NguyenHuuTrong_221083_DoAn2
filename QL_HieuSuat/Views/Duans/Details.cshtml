@{
    ViewData["Title"] = "Chi tiết dự án";

    var parentTasks = Model.Congviecs?
        .Where(c => c.Macongvieccha == null)
        .ToList() ?? new List<QL_HieuSuat.Models.Congviec>();

    int totalTask = Model.Congviecs?.Count() ?? 0;
    int doneTask = Model.Congviecs?.Count(x => x.Matrangthai == 3) ?? 0;

    double totalPoint = 0;
    double donePoint = 0;

    foreach (var cv in Model.Congviecs)
    {
        double point = cv.Diemcongviec ?? 0;
        totalPoint += point;

        if (cv.Matrangthai == 3)
        {
            donePoint += point;
        }
    }

    int projectProgress = totalPoint == 0 ? 0 : (int)((donePoint / totalPoint) * 100);


    //doi mau tien do
    string progressColor = "bg-danger";

    if (projectProgress >= 70)
        progressColor = "bg-success";
    else if (projectProgress >= 30)
        progressColor = "bg-warning";
}

<div class="container mt-4">

    <h2 class="fw-bold mb-3">📁 Chi tiết dự án</h2>

    <div class="card shadow mb-4">

        <div class="card-header bg-primary text-white">
            Thông tin dự án
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-6 mb-3">
                    <b>Tên dự án:</b>
                    <p>@Model.Tenduan</p>
                </div>

                <div class="col-md-6 mb-3">
                    <b>Trạng thái:</b>

                    @{
                        string status = "";
                        string color = "secondary";

                        if (Model.Trangthai == 1)
                        {
                            status = "Chưa bắt đầu";
                            color = "secondary";
                        }
                        else if (Model.Trangthai == 2)
                        {
                            status = "Đang thực hiện";
                            color = "warning";
                        }
                        else if (Model.Trangthai == 3)
                        {
                            status = "Hoàn thành";
                            color = "success";
                        }
                    }

                    <span class="badge bg-@color">@status</span>

                </div>

                <div class="col-md-6 mb-3">
                    <b>Ngày bắt đầu:</b>
                    <p>@Model.Ngaybatdau?.ToString("dd/MM/yyyy")</p>
                </div>

                <div class="col-md-6 mb-3">
                    <b>Ngày kết thúc:</b>
                    <p>@Model.Ngayketthuc?.ToString("dd/MM/yyyy")</p>
                </div>

                <div class="col-md-12 mb-3">
                    <b>Mô tả:</b>
                    <p>@Model.Mota</p>
                </div>

                <div class="col-md-12">

                    <b>Tiến độ dự án</b>

                    <div class="progress mt-2">

                        
                            <div class="progress-bar @progressColor"
                                 role="progressbar"
                                 style="width:@projectProgress%">

                            @projectProgress %

                        </div>

                    </div>

                    <small class="text-muted">
                        @doneTask / @totalTask công việc hoàn thành
                    </small>

                </div>

            </div>

        </div>

    </div>


    <div class="d-flex justify-content-between mb-3">

        <h4>Danh sách công việc</h4>

        <a asp-controller="Congviecs"
           asp-action="Create"
           asp-route-maduan="@Model.Maduan"
           class="btn btn-success">

            ➕ Thêm công việc

        </a>

    </div>


    <table class="table table-hover table-bordered shadow-sm">

        <thead class="table-dark">

            <tr>
                <th>Tên công việc</th>
                <th>Mô tả</th>
                <th>Hạn hoàn thành</th>
                <th>Tiến độ</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>

        </thead>

        <tbody>

            @foreach (var item in parentTasks)
            {
                int progress = 0;
                string badge = "";
                string badgeColor = "secondary";

                switch (item.Matrangthai)
                {
                    case 1:
                        progress = 0;
                        badge = "Chưa bắt đầu";
                        badgeColor = "secondary";
                        break;

                    case 2:
                        progress = 50;
                        badge = "Đang thực hiện";
                        badgeColor = "warning";
                        break;

                    case 4:
                        progress = 80;
                        badge = "Chờ duyệt";
                        badgeColor = "info";
                        break;

                    case 3:
                        progress = 100;
                        badge = "Hoàn thành";
                        badgeColor = "success";
                        break;

                    case 5:
                        progress = 60;
                        badge = "Trễ";
                        badgeColor = "danger";
                        break;

                    case 6:
                        progress = 50;
                        badge = "Không duyệt";
                        badgeColor = "dark";
                        break;

                    case 7:
                        progress = 40;
                        badge = "Tạm dừng";
                        badgeColor = "secondary";
                        break;
                }

                <tr>

                    <td>

                        <a asp-controller="Congviecs"
                           asp-action="Details"
                           asp-route-id="@item.Macongviec"
                           class="fw-bold text-decoration-none">

                            @item.Tencongviec

                        </a>

                    </td>

                    <td>@item.Mota</td>

                    <td>@item.Hanhoanthanh?.ToString("dd/MM/yyyy")</td>

                    <td>

                        <div class="progress">

                            <div class="progress-bar bg-@badgeColor"
                                 role="progressbar"
                                 style="width:@progress%">

                                @progress %

                            </div>

                        </div>

                    </td>

                    <td>

                        <span class="badge bg-@badgeColor">
                            @badge
                        </span>

                    </td>

                    <td>

                        <a class="btn btn-sm btn-info"
                           asp-controller="Congviecs"
                           asp-action="Details"
                           asp-route-id="@item.Macongviec">
                            Xem
                        </a>

                        <a class="btn btn-sm btn-primary"
                           asp-controller="Phancongcongviecs"
                           asp-action="Create"
                           asp-route-macongviec="@item.Macongviec">
                            Giao việc
                        </a>

                    </td>

                </tr>
            }

            @if (!parentTasks.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">Chưa có công việc cha nào trong dự án này.</td>
                </tr>
            }

        </tbody>

    </table>


    <div class="mt-3">

        <a asp-controller="Duans"
           asp-action="Index"
           class="btn btn-secondary">

            ⬅ Quay lại danh sách dự án

        </a>

    </div>

</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        (function () {
            var currentProjectId = @Model.Maduan;

            if (!window.signalR) {
                return;
            }

            var connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/task-progress")
                .withAutomaticReconnect()
                .build();

            connection.on("ProgressChanged", function (payload) {
                if (!payload) return;

                if (payload.projectId === currentProjectId) {
                    location.reload();
                }
            });

            connection.start().catch(function (err) {
                console.error("SignalR connection error:", err);
            });
        })();
    </script>
}

