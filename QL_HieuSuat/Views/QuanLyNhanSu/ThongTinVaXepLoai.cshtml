@model QL_HieuSuat.Models.ViewModels.QuanLyNhanSuThongTinXepLoaiViewModel
@{
    ViewData["Title"] = "Thông tin cá nhân và xếp loại";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="mb-1">Thông tin cá nhân và xếp loại</h2>
        <p class="text-muted mb-0">Tổng quan hồ sơ cá nhân và kỳ đánh giá gần nhất của quản lý nhân sự.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Quản lý nhân viên</a>
</div>

@if (Model.HoSoNhanVien == null)
{
    <div class="alert alert-warning mb-0">
        Chưa tìm thấy hồ sơ nhân sự.
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title mb-3">Hồ sơ cá nhân</h5>
                    <div class="row g-3">
                        <div class="col-md-6"><strong>Họ tên:</strong> @Model.HoSoNhanVien.Hoten</div>
                        <div class="col-md-6"><strong>Email:</strong> @Model.HoSoNhanVien.Email</div>
                        <div class="col-md-6"><strong>Số điện thoại:</strong> @(string.IsNullOrWhiteSpace(Model.HoSoNhanVien.Sdt) ? "-" : Model.HoSoNhanVien.Sdt)</div>
                        <div class="col-md-6"><strong>Phòng ban:</strong> @(Model.HoSoNhanVien.MaphongbanNavigation?.Tenphongban ?? "-")</div>
                        <div class="col-md-6"><strong>Địa chỉ:</strong> @(string.IsNullOrWhiteSpace(Model.HoSoNhanVien.Diachi) ? "-" : Model.HoSoNhanVien.Diachi)</div>
                        <div class="col-md-6"><strong>Ngày vào làm:</strong> @(Model.HoSoNhanVien.Ngayvaolam?.ToString("dd/MM/yyyy") ?? "-")</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title mb-3">Xếp loại gần nhất</h5>
                    <div class="display-6 fw-semibold text-primary mb-2">@(Model.DiemDanhGiaGanNhat?.ToString("0.##") ?? "-")</div>
                    <div class="fs-5 mb-2">@Model.XepLoaiGanNhat</div>
                    <div class="text-muted">@(Model.KyDanhGiaGanNhat ?? "Chưa có dữ liệu kỳ đánh giá")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3 pb-0">
            <h5 class="mb-0">Chi tiết kỳ gần nhất</h5>
        </div>
        <div class="card-body">
            @if (!Model.ChiTietDanhGiaGanNhat.Any())
            {
                <div class="text-muted">Chưa có dữ liệu KPI chi tiết.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Danh mục KPI</th>
                                <th class="text-end">Trọng số</th>
                                <th class="text-end">Điểm</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ChiTietDanhGiaGanNhat)
                            {
                                <tr>
                                    <td>@item.TenDanhMuc</td>
                                    <td class="text-end">@(item.TrongSo?.ToString() ?? "-")</td>
                                    <td class="text-end fw-semibold">@item.DiemSo.ToString("0.##")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
