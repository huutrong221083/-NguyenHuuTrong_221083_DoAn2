@{
    ViewData["Title"] = "Xác nhận yêu cầu";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Xác nhận yêu cầu</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="auth-body">
    <div class="card shadow-lg auth-card">
        <div class="card-body p-4">
            <h4 class="text-center text-primary mb-4">Xác nhận yêu cầu</h4>

            <div class="alert alert-info">
                Nếu email tồn tại trong hệ thống, liên kết đặt lại mật khẩu đã được gửi.
            </div>

            @if (TempData["DevResetLink"] is string devLink)
            {
                <div class="alert alert-warning">
                    <div class="fw-bold mb-2">Môi trường phát triển: liên kết đặt lại mật khẩu</div>
                    <a href="@devLink">@devLink</a>
                </div>
            }

            <div class="text-center mt-3">
                <a asp-action="Login">← Quay lại đăng nhập</a>
            </div>
        </div>
    </div>
</body>
</html>
