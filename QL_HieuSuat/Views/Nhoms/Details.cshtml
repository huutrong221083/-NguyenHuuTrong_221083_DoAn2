@model QL_HieuSuat.Models.Nhom

@{
    ViewData["Title"] = "Chi tiết nhóm";

    var truongNhom = Model.Thanhviennhoms
        .FirstOrDefault(x => x.Vaitrotrongnhom == "Trưởng nhóm");

    var soThanhVien = Model.Thanhviennhoms.Count;
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-info text-white">
            <h4 class="mb-0">📋 Chi tiết nhóm</h4>
        </div>

        <div class="card-body">

            <!-- THÔNG TIN NHÓM -->
            <table class="table table-bordered">

                <tr>
                    <th width="200">Tên nhóm</th>
                    <td>@Model.Tennhom</td>
                </tr>

                <tr>
                    <th>Trưởng nhóm</th>
                    <td>
                        @(truongNhom != null
                            ? truongNhom.ManhanvienNavigation.Hoten
                            : "Chưa có")
                    </td>
                </tr>

                <tr>
                    <th>Số thành viên</th>
                    <td>@soThanhVien</td>
                </tr>

                <tr>
                    <th>Ngày tạo</th>
                    <td>@Model.Ngaytao?.ToString("dd/MM/yyyy")</td>
                </tr>

            </table>

            <!-- DANH SÁCH THÀNH VIÊN -->
            <h5 class="mt-4">👥 Danh sách thành viên</h5>

            <table class="table table-striped table-bordered">

                <thead class="table-light">
                    <tr>
                        <th width="80">STT</th>
                        <th>Họ tên</th>
                        <th width="150">Vai trò</th>
                        <th width="150">Ngày gia nhập</th>
                    </tr>
                </thead>

                <tbody>

                    @{
                        int stt = 1;
                    }

                    @foreach (var tv in Model.Thanhviennhoms)
                    {
                        <tr>

                            <td>@stt</td>

                            <td>@tv.ManhanvienNavigation.Hoten</td>

                            <td>
                                @if (tv.Vaitrotrongnhom == "Trưởng nhóm")
                                {
                                    <span class="badge bg-danger">👑 Trưởng nhóm</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Thành viên</span>
                                }
                            </td>

                            <td>@tv.Ngaygianhap?.ToString("dd/MM/yyyy")</td>

                        </tr>

                        stt++;
                    }

                </tbody>

            </table>

            <div class="mt-3">

                <a asp-action="Edit"
                   asp-route-id="@Model.Manhom"
                   class="btn btn-warning">
                    ✏️ Chỉnh sửa
                </a>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    ← Quay lại
                </a>

            </div>

        </div>

    </div>

</div>