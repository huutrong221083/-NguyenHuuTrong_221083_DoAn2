@model QL_HieuSuat.Models.ViewModels.QuanLyNhanSuYeuCauChinhSuaViewModel
@{
    ViewData["Title"] = "Yêu cầu chỉnh sửa thông tin";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="mb-1">Yêu cầu chỉnh sửa thông tin từ nhân viên</h2>
        <p class="text-muted mb-0">Danh sách hiển thị để theo dõi, chưa áp dụng luồng phê duyệt/chuyển trạng thái.</p>
    </div>
    <span class="badge text-bg-secondary fs-6">@Model.TongYeuCau yêu cầu</span>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.YeuCaus.Any())
        {
            <div class="p-4 text-muted">
                Chưa có dữ liệu yêu cầu chỉnh sửa thông tin trong nhật ký gần đây.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã yêu cầu</th>
                            <th>Nhân viên</th>
                            <th>Email</th>
                            <th>Nội dung</th>
                            <th>Thời gian</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.YeuCaus)
                        {
                            <tr>
                                <td>#@item.MaYeuCau</td>
                                <td>@(string.IsNullOrWhiteSpace(item.TenNhanVien) ? "-" : item.TenNhanVien)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.EmailNhanVien) ? "-" : item.EmailNhanVien)</td>
                                <td>@item.NoiDungYeuCau</td>
                                <td>@(item.ThoiGianGui?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
