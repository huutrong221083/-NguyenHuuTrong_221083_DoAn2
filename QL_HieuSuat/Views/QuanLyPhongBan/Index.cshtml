@model QL_HieuSuat.Models.ViewModels.QuanLyPhongBanDashboardViewModel

@{
    ViewData["Title"] = "Trang trưởng phòng";
}

<div class="container-fluid mt-3">
    @if (Model == null || Model.MaPhongBan == 0)
    {
        <div class="alert alert-warning">
            Không tìm thấy phòng ban thuộc phạm vi quản lý của bạn.
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h3 class="mb-1">Trang trưởng phòng: @Model.TenPhongBan</h3>
                <p class="text-muted mb-0">Trưởng phòng: @Model.TenTruongPhong</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-controller="Phancongcongviecs" asp-action="Create" class="btn btn-outline-secondary">
                    <i class="bi bi-diagram-3"></i> Phân công công việc
                </a>
                <a asp-controller="Congviecs" asp-action="XacNhanTienDo" class="btn btn-outline-primary">
                    <i class="bi bi-check2-square"></i> Duyệt tiến độ
                </a>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Nhân sự trong phòng</div>
                        <div class="h3 fw-bold mb-0">@Model.TongNhanVien</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Tổng công việc liên quan</div>
                        <div class="h3 fw-bold mb-0">@Model.TongCongViec</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Đang thực hiện</div>
                        <div class="h3 fw-bold mb-0">@Model.CongViecDangThucHien</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Chờ duyệt</div>
                        <div class="h3 fw-bold mb-0">@Model.CongViecChoDuyet</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold">Nhân viên trong phòng</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mã NV</th>
                                <th>Họ tên</th>
                                <th>Email</th>
                                <th>Tài khoản</th>
                                <th>CV đang làm</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.NhanViens.Any())
                            {
                                @foreach (var nv in Model.NhanViens)
                                {
                                    <tr>
                                        <td>@nv.MaNhanVien</td>
                                        <td class="fw-semibold">@nv.HoTen</td>
                                        <td>@(string.IsNullOrWhiteSpace(nv.Email) ? "-" : nv.Email)</td>
                                        <td>
                                            @if (nv.CoTaiKhoan)
                                            {
                                                <span class="badge bg-success">Đã có</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Chưa có</span>
                                            }
                                        </td>
                                        <td><span class="badge bg-warning text-dark">@nv.SoCongViecDangLam</span></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-3">Chưa có nhân sự trong phòng.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold">Công việc thuộc phạm vi phòng ban</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Công việc</th>
                                <th>Dự án</th>
                                <th>Tiến độ</th>
                                <th>Trạng thái</th>
                                <th>Hạn</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.CongViecs.Any())
                            {
                                @foreach (var cv in Model.CongViecs)
                                {
                                    var statusClass = cv.Matrangthai == 3 ? "bg-success" : cv.Matrangthai == 4 ? "bg-info" : cv.Matrangthai == 2 ? "bg-warning text-dark" : "bg-secondary";
                                    var statusText = cv.Matrangthai == 3 ? "Hoàn thành" : cv.Matrangthai == 4 ? "Chờ duyệt" : cv.Matrangthai == 2 ? "Đang thực hiện" : "Chưa bắt đầu";

                                    <tr>
                                        <td class="fw-semibold">@cv.TenCongViec</td>
                                        <td>@(string.IsNullOrWhiteSpace(cv.TenDuAn) ? "-" : cv.TenDuAn)</td>
                                        <td style="min-width:180px">
                                            <div class="progress" style="height: 18px;">
                                                <div class="progress-bar bg-success" role="progressbar" style="width:@cv.TienDo%">@cv.TienDo%</div>
                                            </div>
                                        </td>
                                        <td><span class="badge @statusClass">@statusText</span></td>
                                        <td>@(cv.HanHoanThanh?.ToString("dd/MM/yyyy") ?? "-")</td>
                                        <td>
                                            <a asp-controller="Congviecs" asp-action="Details" asp-route-id="@cv.MaCongViec" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-3">Chưa có công việc nào trong phạm vi phòng.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
