@{
    ViewData["Title"] = "Thống kê hiệu suất";

    var qNam = Context.Request.Query["nam"].ToString();
    var qThang = Context.Request.Query["thang"].ToString();
    var qPhongBan = Context.Request.Query["phongban"].ToString();
    var qNhom = Context.Request.Query["nhom"].ToString();
}

<div class="container-fluid mt-4 thongke-page">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <h3 class="fw-bold mb-1">Thống kê hiệu suất tổng quan</h3>
            <p class="text-muted mb-0">Theo dõi KPI, tiến độ công việc và xu hướng nguồn lực trên một màn hình.</p>
        </div>
        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#exportReportModal">
            Xuất file báo cáo
        </button>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form id="formFilter" method="get" asp-action="Index">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label mb-1">Năm</label>
                        <select name="nam" class="form-select auto-filter">
                            <option value="" selected="@string.IsNullOrWhiteSpace(qNam)">Tất cả</option>
                            <option value="2023" selected="@(qNam == "2023")">2023</option>
                            <option value="2024" selected="@(qNam == "2024")">2024</option>
                            <option value="2025" selected="@(qNam == "2025")">2025</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label mb-1">Tháng</label>
                        <select name="thang" class="form-select auto-filter">
                            <option value="" selected="@string.IsNullOrWhiteSpace(qThang)">Tất cả</option>
                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i" selected="@(qThang == i.ToString())">Tháng @i</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label mb-1">Phòng ban</label>
                        <select name="phongban" class="form-select auto-filter">
                            <option value="" selected="@string.IsNullOrWhiteSpace(qPhongBan)">Tất cả</option>
                            @foreach (var pb in ViewBag.PhongBan)
                            {
                                <option value="@pb.Maphongban" selected="@(qPhongBan == pb.Maphongban.ToString())">@pb.Tenphongban</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label mb-1">Nhóm</label>
                        <select name="nhom" class="form-select auto-filter">
                            <option value="" selected="@string.IsNullOrWhiteSpace(qNhom)">Tất cả</option>
                            @foreach (var n in ViewBag.Nhom)
                            {
                                <option value="@n.Manhom" selected="@(qNhom == n.Manhom.ToString())">@n.Tennhom</option>
                            }
                        </select>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-2">
            <div class="metric-card metric-blue">
                <div class="metric-value">@ViewBag.TongNhanVien</div>
                <div class="metric-label">Nhân viên</div>
            </div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="metric-card metric-green">
                <div class="metric-value">@ViewBag.TongDuAn</div>
                <div class="metric-label">Dự án</div>
            </div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="metric-card metric-yellow">
                <div class="metric-value">@ViewBag.TongCongViec</div>
                <div class="metric-label">Công việc</div>
            </div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="metric-card metric-red">
                <div class="metric-value">@ViewBag.TongNhom</div>
                <div class="metric-label">Nhóm</div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="metric-card metric-purple metric-ai">
                <div class="metric-value">@ViewBag.AIKPI%</div>
                <div class="metric-label">AI dự đoán KPI tháng tới</div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div class="fw-semibold">Biểu đồ phân tích</div>
            <div class="d-flex align-items-center gap-2">
                <label for="chartSelector" class="small text-muted mb-0">Chọn biểu đồ</label>
                <select id="chartSelector" class="form-select form-select-sm" style="min-width: 260px;">
                    <option value="chartKPI" selected>KPI trung bình theo tháng</option>
                    <option value="chartTrangThai">Trạng thái công việc</option>
                    <option value="chartTopNV">Top nhân viên theo KPI</option>
                    <option value="chartKyNang">Thống kê kỹ năng</option>
                    <option value="chartPhong">Phân bố công việc theo phòng ban</option>
                    <option value="chartNhom">Phân bố công việc theo nhóm</option>
                    <option value="chartSoSanhDuAn">So sánh ngày thực tế và dự đoán AI theo dự án</option>
                </select>
            </div>
        </div>
        <div class="card-body">
            <div class="chart-panel" data-chart="chartKPI">
                <div class="chart-body chart-h-320"><canvas id="chartKPI"></canvas></div>
            </div>

            <div class="chart-panel d-none" data-chart="chartTrangThai">
                <div class="chart-body chart-h-320"><canvas id="chartTrangThai"></canvas></div>
            </div>

            <div class="chart-panel d-none" data-chart="chartTopNV">
                <div class="chart-body chart-h-320"><canvas id="chartTopNV"></canvas></div>
            </div>

            <div class="chart-panel d-none" data-chart="chartKyNang">
                <div class="chart-body chart-h-320"><canvas id="chartKyNang"></canvas></div>
            </div>

            <div class="chart-panel d-none" data-chart="chartPhong">
                <div class="chart-body chart-h-320"><canvas id="chartPhong"></canvas></div>
            </div>

            <div class="chart-panel d-none" data-chart="chartNhom">
                <div class="chart-body chart-h-320"><canvas id="chartNhom"></canvas></div>
            </div>

            <div class="chart-panel d-none" data-chart="chartSoSanhDuAn">
                <div class="chart-body chart-h-320">
                    <div id="chartSoSanhDuAnEmpty" class="d-none h-100 d-flex align-items-center justify-content-center text-muted">
                        Chưa có dự án hoàn thành để so sánh.
                    </div>
                    <canvas id="chartSoSanhDuAn"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white fw-semibold">Tiến độ dự án</div>
        <div class="card-body p-0">
            <div class="table-responsive project-progress-wrap">
                <table class="table table-sm table-hover align-middle mb-0 project-progress-table">
                    <thead class="table-light">
                        <tr>
                            <th>Dự án</th>
                            <th style="min-width: 260px;">Tiến độ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var da in ViewBag.DuAnTienDo)
                        {
                            var percent = da.TongCV == 0 ? 0 : (da.HoanThanh * 100 / da.TongCV);
                            <tr>
                                <td class="fw-semibold">@da.TenDuAn</td>
                                <td>
                                    <div class="progress" style="height: 0.85rem;">
                                        <div class="progress-bar bg-success" style="width:@percent%">@percent%</div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white fw-semibold">Báo cáo hiệu suất nhân sự</div>
        <div class="card-body">
            <div class="row g-3 mb-4">
                <div class="col-md-3 col-6">
                    <div class="report-metric report-slate">
                        <div class="report-metric-label">Nhân sự có dữ liệu KPI</div>
                        <div class="report-metric-value">@ViewBag.BaoCaoSoNhanVien</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="report-metric report-teal">
                        <div class="report-metric-label">Đạt mức tốt (>= 80)</div>
                        <div class="report-metric-value">@ViewBag.BaoCaoSoDatMucTot</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="report-metric report-amber">
                        <div class="report-metric-label">Tỷ lệ đạt mức tốt</div>
                        <div class="report-metric-value">@ViewBag.BaoCaoTyLeDatMucTot%</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="report-metric report-rose">
                        <div class="report-metric-label">Nhân sự cần cải thiện</div>
                        <div class="report-metric-value">@ViewBag.BaoCaoSoCanhBao</div>
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-lg-4">
                    <div class="alert alert-warning h-100 mb-0">
                        <div class="fw-semibold mb-2">Danh sách cần ưu tiên hỗ trợ</div>
                        @if (ViewBag.BaoCaoCanhBaoNhanVien != null && ViewBag.BaoCaoCanhBaoNhanVien.Count > 0)
                        {
                            <ul class="mb-0 ps-3">
                                @foreach (var nv in ViewBag.BaoCaoCanhBaoNhanVien)
                                {
                                    <li>@nv.TenNhanVien (@nv.DiemTrungBinh điểm)</li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="mb-0">Chưa có nhân sự ở ngưỡng cảnh báo.</div>
                        }
                    </div>
                </div>

                <div class="col-lg-8">
                    <div class="table-responsive report-fixed-table-wrap">
                        <table class="table table-sm table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>STT</th>
                                    <th>Nhân viên</th>
                                    <th>Phòng ban</th>
                                    <th>KPI TB</th>
                                    <th>KPI gần nhất</th>
                                    <th>Số kỳ</th>
                                    <th>Xếp loại</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int stt = 1; }
                                @foreach (var nv in ViewBag.BaoCaoNhanVien)
                                {
                                    var diemTB = Convert.ToDouble(nv.DiemTrungBinh);
                                    var xepLoai = diemTB >= 85 ? "Xuất sắc" : diemTB >= 70 ? "Khá" : diemTB >= 60 ? "Trung bình" : "Cần cải thiện";
                                    var badge = diemTB >= 85 ? "bg-success" : diemTB >= 70 ? "bg-primary" : diemTB >= 60 ? "bg-warning text-dark" : "bg-danger";

                                    <tr>
                                        <td>@stt</td>
                                        <td class="fw-semibold">@nv.TenNhanVien</td>
                                        <td>@nv.PhongBan</td>
                                        <td>@nv.DiemTrungBinh</td>
                                        <td>@nv.DiemGanNhat</td>
                                        <td>@nv.SoKyDanhGia</td>
                                        <td><span class="badge @badge">@xepLoai</span></td>
                                    </tr>

                                    stt++;
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<style>
    .project-progress-wrap {
        max-height: 300px;
        overflow-y: auto;
    }

    .report-fixed-table-wrap {
        max-height: 360px;
        overflow-y: auto;
    }

    .project-progress-wrap thead th,
    .report-fixed-table-wrap thead th {
        position: sticky;
        top: 0;
        z-index: 1;
        background: #f8f9fa;
    }

    .project-progress-table td,
    .project-progress-table th {
        padding-top: 0.45rem;
        padding-bottom: 0.45rem;
    }
</style>

<div class="modal fade" id="exportReportModal" tabindex="-1" aria-labelledby="exportReportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exportReportModalLabel">Tùy chọn xuất báo cáo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form method="get" asp-action="ExportReport">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Loại file</label>
                        <select class="form-select" name="format" required>
                            <option value="excel" selected>Excel (.xlsx)</option>
                            <option value="pdf">PDF (.pdf)</option>
                        </select>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Loại báo cáo</label>
                        <select class="form-select" name="reportType" required>
                            <option value="hieu-suat-nhan-vien" selected>Hiệu suất nhân viên</option>
                            <option value="tien-do-du-an">Tiến độ dự án</option>
                            <option value="trang-thai-cong-viec">Trạng thái công việc</option>
                            <option value="thong-ke-ky-nang">Thống kê kỹ năng</option>
                            <option value="tong-quan-he-thong">Tổng quan hệ thống</option>
                        </select>
                    </div>

                    <div class="small text-muted">
                        Báo cáo sẽ áp dụng theo bộ lọc đang chọn (năm, tháng, phòng ban, nhóm) khi phù hợp.
                    </div>

                    <input type="hidden" name="nam" value="@qNam" />
                    <input type="hidden" name="thang" value="@qThang" />
                    <input type="hidden" name="phongban" value="@qPhongBan" />
                    <input type="hidden" name="nhom" value="@qNhom" />
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success">Xuất báo cáo</button>
                </div>
            </form>
        </div>
    </div>
</div>

@{
    var hoatDongSoSanhDuAn = (ViewBag.HoatDongSoSanhDuAn as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
    var soSanhDuAnLabels = hoatDongSoSanhDuAn.Select(x => (x?.TenDuAn?.ToString() ?? "-")).ToList();
    var soSanhDuAnNgayThucTe = hoatDongSoSanhDuAn
        .Select(x => ((DateTime?)x?.NgayHoanThanhThucTe)?.ToString("yyyy-MM-dd"))
        .ToList();
    var soSanhDuAnNgayAIDuDoan = hoatDongSoSanhDuAn
        .Select(x => ((DateTime?)x?.NgayDuDoanAI)?.ToString("yyyy-MM-dd"))
        .ToList();
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const chartInstances = {};

    const baseFont = {
        family: "Segoe UI, Tahoma, sans-serif",
        size: 12
    };

    const gridColor = "rgba(120,130,150,0.15)";

    const commonOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                labels: {
                    font: baseFont
                }
            }
        }
    };

    const trangThaiLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TrangThaiLabels));
    const trangThaiData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TrangThaiData));

    const normalizeLabel = (value) =>
        (value || "")
            .toString()
            .trim()
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "");

    const statusColorMap = {
        "chua bat dau": "#22c55e",
        "dang thuc hien": "#f59e0b",
        "hoan thanh": "#3b82f6",
        "cho duyet": "#6366f1",
        "tre": "#8b5cf6",
        "khong duyet": "#ef4444",
        "tam dung": "#06b6d4"
    };

    const fallbackStatusColors = ["#f97316", "#14b8a6", "#ec4899", "#84cc16", "#a855f7", "#0ea5e9"];
    const trangThaiColors = trangThaiLabels.map((label, idx) => {
        const key = normalizeLabel(label);
        return statusColorMap[key] || fallbackStatusColors[idx % fallbackStatusColors.length];
    });

    chartInstances.chartTrangThai = new Chart(document.getElementById("chartTrangThai"), {
        type: "doughnut",
        data: {
            labels: trangThaiLabels,
            datasets: [{
                data: trangThaiData,
                backgroundColor: trangThaiColors
            }]
        },
        options: {
            ...commonOptions,
            cutout: "62%"
        }
    });

    chartInstances.chartKPI = new Chart(document.getElementById("chartKPI"), {
        type: "line",
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Thang)),
            datasets: [{
                label: "KPI trung bình",
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.DiemKPI)),
                borderWidth: 3,
                borderColor: "#2d7ff9",
                backgroundColor: "rgba(45,127,249,0.14)",
                fill: true,
                tension: 0.35,
                pointRadius: 2
            }]
        },
        options: {
            ...commonOptions,
            scales: {
                y: { beginAtZero: true, grid: { color: gridColor } },
                x: { grid: { color: "transparent" } }
            }
        }
    });

    chartInstances.chartTopNV = new Chart(document.getElementById("chartTopNV"), {
        type: "bar",
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TopNVLabels)),
            datasets: [{
                label: "Điểm KPI",
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TopNVData)),
                backgroundColor: "#22c55e"
            }]
        },
        options: {
            ...commonOptions,
            scales: {
                y: { beginAtZero: true, grid: { color: gridColor } },
                x: { grid: { color: "transparent" } }
            }
        }
    });

    chartInstances.chartKyNang = new Chart(document.getElementById("chartKyNang"), {
        type: "bar",
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.KyNangLabels)),
            datasets: [{
                label: "Số nhân viên",
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.KyNangData)),
                backgroundColor: "#8b5cf6"
            }]
        },
        options: {
            ...commonOptions,
            scales: {
                y: { beginAtZero: true, grid: { color: gridColor } },
                x: { grid: { color: "transparent" } }
            }
        }
    });

    chartInstances.chartPhong = new Chart(document.getElementById("chartPhong"), {
        type: "bar",
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.PhongLabels)),
            datasets: [{
                label: "Số công việc",
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.PhongData)),
                backgroundColor: "#f59e0b"
            }]
        },
        options: {
            ...commonOptions,
            scales: {
                y: { beginAtZero: true, grid: { color: gridColor } },
                x: { grid: { color: "transparent" } }
            }
        }
    });

    chartInstances.chartNhom = new Chart(document.getElementById("chartNhom"), {
        type: "bar",
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.NhomLabels)),
            datasets: [{
                label: "Số công việc",
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.NhomData)),
                backgroundColor: "#ef4444"
            }]
        },
        options: {
            ...commonOptions,
            scales: {
                y: { beginAtZero: true, grid: { color: gridColor } },
                x: { grid: { color: "transparent" } }
            }
        }
    });

    const chartSoSanhDuAnElement = document.getElementById("chartSoSanhDuAn");
    const chartSoSanhDuAnEmptyElement = document.getElementById("chartSoSanhDuAnEmpty");
    if (chartSoSanhDuAnElement) {
        const toTimestamp = (isoDate) => {
            if (!isoDate) {
                return null;
            }

            const time = Date.parse(isoDate);
            return Number.isNaN(time) ? null : time;
        };

        const formatTimestamp = (ts) => {
            if (ts === null || ts === undefined || Number.isNaN(ts)) {
                return "-";
            }

            return new Date(ts).toLocaleDateString("vi-VN");
        };

        const rawNgayThucTe = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(soSanhDuAnNgayThucTe));
        const rawNgayAIDuDoan = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(soSanhDuAnNgayAIDuDoan));

        const ngayThucTeData = rawNgayThucTe.map((x) => toTimestamp(x));
        const ngayAIDuDoanData = rawNgayAIDuDoan.map((x) => toTimestamp(x));
        const allValues = [...ngayThucTeData, ...ngayAIDuDoanData].filter((x) => x !== null);

        if (allValues.length === 0) {
            chartSoSanhDuAnElement.classList.add("d-none");
            chartSoSanhDuAnEmptyElement?.classList.remove("d-none");
        } else {
            chartSoSanhDuAnElement.classList.remove("d-none");
            chartSoSanhDuAnEmptyElement?.classList.add("d-none");
        }

        if (allValues.length > 0) {
            chartInstances.chartSoSanhDuAn = new Chart(chartSoSanhDuAnElement, {
                type: "bar",
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(soSanhDuAnLabels)),
                    datasets: [{
                        label: "Ngày hoàn thành thực tế",
                        data: ngayThucTeData,
                        backgroundColor: "rgba(22,163,74,0.78)",
                        borderColor: "#16a34a",
                        borderWidth: 1,
                        borderRadius: 6
                    }, {
                        label: "Ngày dự đoán AI",
                        data: ngayAIDuDoanData,
                        backgroundColor: "rgba(45,127,249,0.78)",
                        borderColor: "#2d7ff9",
                        borderWidth: 1,
                        borderRadius: 6
                    }]
                },
                options: {
                    ...commonOptions,
                    plugins: {
                        ...commonOptions.plugins,
                        tooltip: {
                            callbacks: {
                                label: (context) => {
                                    const label = context.dataset.label || "";
                                    const value = context.parsed?.y;
                                    return `${label}: ${formatTimestamp(value)}`;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            grid: { color: gridColor },
                            ticks: {
                                callback: (value) => formatTimestamp(Number(value))
                            }
                        },
                        x: {
                            grid: { color: "transparent" },
                            ticks: {
                                maxRotation: 40,
                                minRotation: 0
                            }
                        }
                    }
                }
            });
        }
    }

    const chartSelector = document.getElementById("chartSelector");
    const chartPanels = Array.from(document.querySelectorAll(".chart-panel"));

    const showChartPanel = (chartId) => {
        chartPanels.forEach((panel) => {
            const isActive = panel.dataset.chart === chartId;
            panel.classList.toggle("d-none", !isActive);
        });

        const chart = chartInstances[chartId];
        if (chart) {
            setTimeout(() => chart.resize(), 50);
        }
    };

    if (chartSelector) {
        showChartPanel(chartSelector.value);
        chartSelector.addEventListener("change", (event) => {
            showChartPanel(event.target.value);
        });
    }

    document.querySelectorAll(".auto-filter").forEach((select) => {
        select.addEventListener("change", () => {
            document.getElementById("formFilter").submit();
        });
    });
</script>
