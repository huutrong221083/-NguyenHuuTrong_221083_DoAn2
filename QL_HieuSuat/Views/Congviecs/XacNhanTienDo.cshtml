@model List<QL_HieuSuat.Models.ViewModels.XacNhanTienDoItemViewModel>

@{
    ViewData["Title"] = "Xác nhận tiến độ";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-1">Xác nhận tiến độ công việc</h3>
            <p class="text-muted mb-0">Dành cho trưởng nhóm và trưởng phòng theo phạm vi phụ trách.</p>
        </div>
    </div>

    @if (TempData["UploadSuccess"] != null)
    {
        <div class="alert alert-success">@TempData["UploadSuccess"]</div>
    }

    @if (TempData["UploadError"] != null)
    {
        <div class="alert alert-danger">@TempData["UploadError"]</div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            Hiện không có công việc nào ở trạng thái chờ duyệt hoặc trễ trong phạm vi quản lý của bạn.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                Danh sách công việc chờ duyệt (@Model.Count)
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Công việc</th>
                                <th>Dự án</th>
                                <th>Người nhận</th>
                                <th>Tiến độ mới nhất</th>
                                <th>Ưu tiên</th>
                                <th>Hạn hoàn thành</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var progress = Math.Max(0, Math.Min(100, item.TienDoPhanTram));
                                var dueClass = item.HanHoanThanh.HasValue && item.HanHoanThanh.Value.Date < DateTime.Today
                                    ? "text-danger fw-semibold"
                                    : "text-body";

                                <tr>
                                    <td>
                                        <a asp-action="Details"
                                           asp-route-id="@item.MaCongViec"
                                           class="fw-semibold text-decoration-none">
                                            @item.TenCongViec
                                        </a>
                                    </td>
                                    <td>@(string.IsNullOrWhiteSpace(item.TenDuAn) ? "-" : item.TenDuAn)</td>
                                    <td>
                                        @if (item.NguoiNhan.Any())
                                        {
                                            foreach (var nguoi in item.NguoiNhan)
                                            {
                                                <span class="badge bg-primary me-1 mb-1">@nguoi</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">Chưa có người nhận</span>
                                        }
                                    </td>
                                    <td style="min-width: 180px;">
                                        <div class="progress" style="height: 18px;">
                                            <div class="progress-bar bg-success" role="progressbar" style="width:@progress%">
                                                @Math.Round(progress)%
                                            </div>
                                        </div>
                                    </td>
                                    <td>@(item.MucUuTien?.ToString() ?? "-")</td>
                                    <td class="@dueClass">@(item.HanHoanThanh?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td class="text-center" style="min-width: 180px;">
                                        <a asp-action="Approve"
                                           asp-route-id="@item.MaCongViec"
                                           class="btn btn-success btn-sm me-1">
                                            Duyệt
                                        </a>
                                        <button type="button"
                                                class="btn btn-outline-danger btn-sm btn-reject-task"
                                                data-task-id="@item.MaCongViec"
                                                data-task-name="@item.TenCongViec"
                                                data-bs-toggle="modal"
                                                data-bs-target="#rejectTaskModal">
                                            Không duyệt
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="rejectTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Reject" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Không duyệt công việc</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="rejectTaskId" name="id" />
                    <p class="mb-2">Công việc: <strong id="rejectTaskName">-</strong></p>
                    <label for="rejectReason" class="form-label">Lý do không duyệt</label>
                    <textarea id="rejectReason"
                              name="reason"
                              class="form-control"
                              rows="4"
                              required
                              placeholder="Nhập lý do để nhân viên chỉnh sửa công việc..."></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger">Xác nhận không duyệt</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var rejectButtons = document.querySelectorAll(".btn-reject-task");
            var taskIdInput = document.getElementById("rejectTaskId");
            var taskNameLabel = document.getElementById("rejectTaskName");
            var reasonInput = document.getElementById("rejectReason");

            rejectButtons.forEach(function (button) {
                button.addEventListener("click", function () {
                    taskIdInput.value = button.getAttribute("data-task-id") || "";
                    taskNameLabel.textContent = button.getAttribute("data-task-name") || "-";
                    reasonInput.value = "";
                });
            });
        });
    </script>
}
