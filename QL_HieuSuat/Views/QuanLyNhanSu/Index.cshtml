@model QL_HieuSuat.Models.ViewModels.QuanLyNhanSuDashboardViewModel

@{
    ViewData["Title"] = "Quản lý nhân viên";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-1">Quản lý nhân viên</h3>
            <p class="text-muted mb-0">Theo dõi nhân viên, tài khoản và mức độ tham gia công việc.</p>
        </div>
        <div>
            <a asp-controller="Nhanviens" asp-action="Create" class="btn btn-success">
                <i class="bi bi-person-plus"></i> Thêm nhân viên
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Tổng nhân sự</div>
                    <div class="h3 fw-bold mb-0">@Model.TongNhanSu</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Phòng ban</div>
                    <div class="h3 fw-bold mb-0">@Model.TongPhongBan</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Nhóm</div>
                    <div class="h3 fw-bold mb-0">@Model.TongNhom</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Tài khoản đã cấp</div>
                    <div class="h3 fw-bold mb-0">@Model.SoNhanSuCoTaiKhoan</div>
                    <div class="small text-muted">Chưa có: @Model.SoNhanSuChuaCoTaiKhoan</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <form id="hrFilterForm" method="get" class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">Bộ lọc nhanh</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-funnel"></i></span>
                        <input id="alphabetFilterInput"
                               type="text"
                               name="alphabetFilter"
                               value="@Model.AlphabetFilter"
                               maxlength="1"
                               class="form-control text-uppercase"
                               placeholder="A" />
                    </div>
                    <small class="text-muted">Nhập chữ cái để sắp xếp tên ngay.</small>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Tên / Email / SĐT</label>
                    <input type="text" name="keyword" value="@Model.Keyword" class="form-control" placeholder="Nhập từ khóa" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Phòng ban</label>
                    <select name="phongBanFilter" class="form-select">
                        <option value="">Tất cả phòng ban</option>
                        @foreach (var pb in (List<SelectListItem>)ViewBag.PhongBanOptions)
                        {
                            if (Model.PhongBanFilter.HasValue && pb.Value == Model.PhongBanFilter.Value.ToString())
                            {
                                <option value="@pb.Value" selected>@pb.Text</option>
                            }
                            else
                            {
                                <option value="@pb.Value">@pb.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Có tài khoản</label>
                    <select name="coTaiKhoanFilter" class="form-select">
                        @if (!Model.CoTaiKhoanFilter.HasValue)
                        {
                            <option value="" selected>Tất cả</option>
                        }
                        else
                        {
                            <option value="">Tất cả</option>
                        }

                        @if (Model.CoTaiKhoanFilter == true)
                        {
                            <option value="true" selected>Có</option>
                        }
                        else
                        {
                            <option value="true">Có</option>
                        }

                        @if (Model.CoTaiKhoanFilter == false)
                        {
                            <option value="false" selected>Không</option>
                        }
                        else
                        {
                            <option value="false">Không</option>
                        }
                    </select>
                </div>

                <div class="col-md-1">
                    <label class="form-label">Kinh nghiệm</label>
                    <select name="kinhNghiemTu" class="form-select">
                        @if (!Model.KinhNghiemTu.HasValue)
                        {
                            <option value="" selected>Tất cả</option>
                        }
                        else
                        {
                            <option value="">Tất cả</option>
                        }

                        @if (Model.KinhNghiemTu == 1)
                        {
                            <option value="1" selected>>=1</option>
                        }
                        else
                        {
                            <option value="1">>=1</option>
                        }

                        @if (Model.KinhNghiemTu == 3)
                        {
                            <option value="3" selected>>=3</option>
                        }
                        else
                        {
                            <option value="3">>=3</option>
                        }

                        @if (Model.KinhNghiemTu == 5)
                        {
                            <option value="5" selected>>=5</option>
                        }
                        else
                        {
                            <option value="5">>=5</option>
                        }

                        @if (Model.KinhNghiemTu == 10)
                        {
                            <option value="10" selected>>=10</option>
                        }
                        else
                        {
                            <option value="10">>=10</option>
                        }
                    </select>
                </div>

                <div class="col-md-1">
                    <label class="form-label">Độ tuổi</label>
                    <input type="number" name="doTuoi" value="@Model.DoTuoi" min="18" class="form-control" placeholder="VD:25" />
                </div>

                <div class="col-md-1 d-grid">
                    <button class="btn btn-primary" type="submit">Lọc</button>
                </div>
            </form>

            <div class="d-flex flex-wrap gap-2 mt-3">
                <a class="btn btn-outline-success"
                   asp-action="ExportCsv"
                   asp-route-keyword="@Model.Keyword"
                   asp-route-alphabetFilter="@Model.AlphabetFilter"
                   asp-route-kinhNghiemTu="@Model.KinhNghiemTu"
                   asp-route-doTuoi="@Model.DoTuoi"
                   asp-route-phongBanFilter="@Model.PhongBanFilter"
                   asp-route-coTaiKhoanFilter="@Model.CoTaiKhoanFilter">
                    <i class="bi bi-download"></i> Xuất theo bộ lọc hiện tại
                </a>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white fw-semibold">
            Danh sách nhân sự (@Model.NhanViens.Count)
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã NV</th>
                            <th>Họ tên</th>
                            <th>Email nhân sự</th>
                            <th>Phòng ban</th>
                            <th>Số nhóm</th>
                            <th>Tài khoản</th>
                            <th>Kinh nghiệm</th>
                            <th>Tuổi</th>
                            <th>CV đang làm</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.NhanViens.Any())
                        {
                            @foreach (var nv in Model.NhanViens)
                            {
                                <tr>
                                    <td>@nv.MaNhanVien</td>
                                    <td class="fw-semibold">@nv.HoTen</td>
                                    <td>@(string.IsNullOrWhiteSpace(nv.EmailNhanVien) ? "-" : nv.EmailNhanVien)</td>
                                    <td>@(string.IsNullOrWhiteSpace(nv.TenPhongBan) ? "-" : nv.TenPhongBan)</td>
                                    <td>@nv.SoNhomThamGia</td>
                                    <td>
                                        @if (nv.CoTaiKhoan)
                                        {
                                            <span class="badge bg-success">Đã có</span>
                                            <div class="small text-muted">@nv.EmailTaiKhoan</div>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Chưa có</span>
                                        }
                                    </td>
                                    <td>@nv.KinhNghiem.ToString("0.##") năm</td>
                                    <td>@(nv.Tuoi.HasValue ? nv.Tuoi + "" : "-")</td>
                                    <td>
                                        <span class="badge @(nv.CongViecDangThucHien > 0 ? "bg-warning text-dark" : "bg-light text-dark")">
                                            @nv.CongViecDangThucHien
                                        </span>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a class="btn btn-outline-info"
                                               asp-controller="Nhanviens"
                                               asp-action="Details"
                                               asp-route-id="@nv.MaNhanVien">Xem</a>
                                            <a class="btn btn-outline-primary"
                                               asp-controller="Nhanviens"
                                               asp-action="Edit"
                                               asp-route-id="@nv.MaNhanVien">Sửa</a>
                                            <a class="btn btn-outline-danger"
                                               asp-controller="Nhanviens"
                                               asp-action="Delete"
                                               asp-route-id="@nv.MaNhanVien">Xóa</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="10" class="text-center text-muted py-4">Không có dữ liệu phù hợp bộ lọc.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        var form = document.getElementById("hrFilterForm");
        var alphabetInput = document.getElementById("alphabetFilterInput");

        if (!form || !alphabetInput) {
            return;
        }

        alphabetInput.addEventListener("input", function () {
            var value = (alphabetInput.value || "").trim();
            if (value.length <= 1) {
                form.submit();
            }
        });
    })();
</script>
