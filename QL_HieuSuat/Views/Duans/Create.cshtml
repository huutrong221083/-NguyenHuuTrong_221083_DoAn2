@model QL_HieuSuat.Models.Duan

@{
    ViewData["Title"] = "Tạo dự án";
}

<div class="container mt-4">

    <h2 class="fw-bold mb-4">➕ Tạo dự án mới</h2>

    <div class="card shadow">

        <div class="card-header bg-success text-white">
            Thông tin dự án
        </div>

        <div class="card-body">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Tenduan" class="form-label">Tên dự án</label>
                        <input asp-for="Tenduan" class="form-control" />
                        <span asp-validation-for="Tenduan" class="text-danger"></span>
                    </div>

                    @* <div class="col-md-6 mb-3">
                        <label asp-for="Trangthai" class="form-label">Trạng thái</label>

                        <select asp-for="Trangthai" class="form-control">
                            <option value="1">Chưa bắt đầu</option>
                            <option value="2">Đang thực hiện</option>
                            <option value="3">Hoàn thành</option>
                        </select>

                        <span asp-validation-for="Trangthai" class="text-danger"></span>
                    </div> *@

                    <div class="col-md-6 mb-3">
                        <label asp-for="Ngaybatdau" class="form-label">Ngày bắt đầu</label>
                        <input asp-for="Ngaybatdau" type="date" class="form-control" />
                        <span asp-validation-for="Ngaybatdau" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Ngayketthuc" class="form-label">Ngày kết thúc</label>
                        <input asp-for="Ngayketthuc" type="date" class="form-control" />
                        <span asp-validation-for="Ngayketthuc" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Mota" class="form-label">Mô tả</label>
                        <textarea asp-for="Mota" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Mota" class="text-danger"></span>
                    </div>

                </div>

                <div class="mt-3">

                    <button type="submit" class="btn btn-success">
                        💾 Lưu dự án
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        ↩ Quay lại
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}