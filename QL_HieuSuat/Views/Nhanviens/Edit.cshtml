@model QL_HieuSuat.Models.Nhanvien

@{
    ViewData["Title"] = "Chỉnh sửa nhân viên";
}

<div class="container mt-4">

    <div class="card shadow border-0">

        <!-- HEADER -->
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                ✏️ Chỉnh sửa thông tin nhân viên
            </h5>

            <a asp-action="Index" class="btn btn-light btn-sm">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Manhanvien" />

                <div class="row g-4">

                    <!-- CỘT TRÁI -->
                    <div class="col-md-6">

                        <div class="form-group">
                            <label asp-for="Hoten" class="form-label fw-bold">Họ và tên</label>
                            <input asp-for="Hoten" class="form-control" placeholder="Nhập họ tên..." />
                            <span asp-validation-for="Hoten" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Ngaysinh" class="form-label fw-bold">Ngày sinh</label>
                            <input asp-for="Ngaysinh" type="date" class="form-control" />
                            <span asp-validation-for="Ngaysinh" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Gioitinh" class="form-label fw-bold d-block">Giới tính</label>

                            <div class="btn-group" role="group">
                                <input type="radio" class="btn-check" asp-for="Gioitinh" value="Nam" id="nam">
                                <label class="btn btn-outline-primary" for="nam">Nam</label>

                                <input type="radio" class="btn-check" asp-for="Gioitinh" value="Nữ" id="nu">
                                <label class="btn btn-outline-primary" for="nu">Nữ</label>
                            </div>

                            <span asp-validation-for="Gioitinh" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Cccd" class="form-label fw-bold">CCCD</label>
                            <input asp-for="Cccd" class="form-control" placeholder="Nhập CCCD..." />
                            <span asp-validation-for="Cccd" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Diachi" class="form-label fw-bold">Địa chỉ</label>
                            <input asp-for="Diachi" class="form-control" placeholder="Nhập địa chỉ..." />
                            <span asp-validation-for="Diachi" class="text-danger"></span>
                        </div>

                    </div>


                    <!-- CỘT PHẢI -->
                    <div class="col-md-6">

                        <div class="form-group">
                            <label asp-for="Maphongban" class="form-label fw-bold">Phòng ban</label>
                            <select asp-for="Maphongban"
                                    class="form-select"
                                    asp-items="ViewBag.Maphongban">
                            </select>
                            <span asp-validation-for="Maphongban" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Email" class="form-label fw-bold">Email</label>
                            <input asp-for="Email"
                                   type="email"
                                   class="form-control"
                                   placeholder="example@email.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Sdt" class="form-label fw-bold">Số điện thoại</label>
                            <input asp-for="Sdt"
                                   class="form-control"
                                   placeholder="Nhập số điện thoại..." />
                            <span asp-validation-for="Sdt" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Ngayvaolam" class="form-label fw-bold">Ngày vào làm</label>
                            <input asp-for="Ngayvaolam" type="date" class="form-control" />
                            <span asp-validation-for="Ngayvaolam" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Trangthai" class="form-label fw-bold">Trạng thái</label>
                            <select asp-for="Trangthai" class="form-select">
                                <option value="1">Đang làm</option>
                                <option value="0">Nghỉ việc</option>
                            </select>
                            <span asp-validation-for="Trangthai" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Sonamkinhnghiem" class="form-label fw-bold">Số năm kinh nghiệm</label>
                            <input asp-for="Sonamkinhnghiem"
                                   type="number"
                                   class="form-control" />
                            <span asp-validation-for="Sonamkinhnghiem" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="DiemkpiTichluy" class="form-label fw-bold">Điểm KPI tích lũy</label>
                            <input asp-for="DiemkpiTichluy"
                                   type="number"
                                   step="0.01"
                                   class="form-control" />
                            <span asp-validation-for="DiemkpiTichluy" class="text-danger"></span>
                        </div>

                    </div>

                </div>


                <!-- FOOTER BUTTON -->
                <div class="mt-4 text-end">

                    <button type="submit" class="btn btn-success px-4">
                        💾 Lưu thay đổi
                    </button>

                </div>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}