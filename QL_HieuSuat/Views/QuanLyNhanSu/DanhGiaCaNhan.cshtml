@model QL_HieuSuat.Models.ViewModels.QuanLyNhanSuDanhGiaCaNhanViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Xem đánh giá cá nhân";
    var labelsJson = JsonSerializer.Serialize(Model.BieuDoNhan);
    var dataJson = JsonSerializer.Serialize(Model.BieuDoDiem);
}

<style>
    .kpi-chart-wrap {
        position: relative;
        height: 320px;
        max-height: 50vh;
    }

    @@media (max-width: 991.98px) {
        .kpi-chart-wrap {
            height: 240px;
            max-height: none;
        }
    }
</style>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="mb-1">Xem đánh giá cá nhân</h2>
        <p class="text-muted mb-0">Lịch sử đánh giá KPI của @(!string.IsNullOrWhiteSpace(Model.TenNhanVien) ? Model.TenNhanVien : "quản lý nhân sự").</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted mb-1">Kỳ đang xem</div>
                <div class="h5 mb-2">@(Model.KyDangXem ?? "-")</div>
                <div class="display-6 text-primary fw-semibold mb-2">@(Model.DiemKyDangXem?.ToString("0.##") ?? "-")</div>
                <div class="fw-semibold">@Model.XepLoaiKyDangXem</div>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h6 class="mb-3">Biểu đồ điểm theo kỳ</h6>
                <div class="kpi-chart-wrap">
                    <canvas id="kpiChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <h6 class="mb-0">Lịch sử kỳ đánh giá</h6>
            </div>
            <div class="card-body p-0">
                @if (!Model.LichSuDanhGia.Any())
                {
                    <div class="p-3 text-muted">Chưa có dữ liệu lịch sử đánh giá.</div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var ky in Model.LichSuDanhGia)
                        {
                            <a asp-action="DanhGiaCaNhan" asp-route-ky="@ky.MaKy" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-semibold">Tháng @(ky.Thang?.ToString("D2") ?? "--")/@(ky.Nam?.ToString() ?? "----")</div>
                                    <small class="text-muted">@ky.XepLoai - @ky.SoDanhMuc danh mục</small>
                                </div>
                                <span class="badge text-bg-primary rounded-pill">@ky.DiemTongHop.ToString("0.##")</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <h6 class="mb-0">Chi tiết kỳ đang xem</h6>
            </div>
            <div class="card-body">
                @if (!Model.ChiTietKyDangXem.Any())
                {
                    <div class="text-muted">Chưa có dữ liệu KPI chi tiết cho kỳ này.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Danh mục KPI</th>
                                    <th class="text-end">Trọng số</th>
                                    <th class="text-end">Điểm</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.ChiTietKyDangXem)
                                {
                                    <tr>
                                        <td>@item.TenDanhMuc</td>
                                        <td class="text-end">@(item.TrongSo?.ToString() ?? "-")</td>
                                        <td class="text-end fw-semibold">@item.DiemSo.ToString("0.##")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (function () {
            const labels = @Html.Raw(labelsJson);
            const data = @Html.Raw(dataJson);
            const canvas = document.getElementById('kpiChart');
            if (!canvas || !Array.isArray(labels) || labels.length === 0) {
                return;
            }

            new Chart(canvas, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Điểm tổng hợp',
                        data: data,
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13,110,253,0.15)',
                        borderWidth: 2,
                        pointRadius: 4,
                        tension: 0.25,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            suggestedMax: 100
                        }
                    }
                }
            });
        })();
    </script>
}
