@{
    ViewData["Title"] = "Đặt lại mật khẩu thành công";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Đặt lại mật khẩu thành công</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="auth-body">
    <div class="card shadow-lg auth-card">
        <div class="card-body p-4">
            <h4 class="text-center text-success mb-4">Đặt lại mật khẩu thành công</h4>

            <div class="alert alert-success">
                Mật khẩu của bạn đã được cập nhật. Vui lòng đăng nhập lại.
            </div>

            <div class="text-center mt-3">
                <a asp-action="Login" class="btn btn-primary">Đến trang đăng nhập</a>
            </div>
        </div>
    </div>
</body>
</html>
